<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Phone Sim — Design &amp; Trade</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#0b0d10;
    --panel:#12151a;
    --panel-2:#171b21;
    --line:#232830;
    --line-soft:#1b2027;
    --text:#e6e9ee;
    --muted:#828b98;
    --muted-2:#5b6371;
    --accent:#5eead4;
    --accent-dim:#2c4744;
    --danger:#f2748a;
    --danger-dim:#3a2229;
    --warn:#f0b458;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:var(--bg);
    color:var(--text);
    font-family:'Space Grotesk', system-ui, sans-serif;
    min-height:100vh;
  }
  .mono{ font-family:'JetBrains Mono', monospace; }
  ::selection{ background:var(--accent-dim); }

  /* ---------- layout shell ---------- */
  .shell{ max-width:1080px; margin:0 auto; padding:0 20px 60px; }
  .topbar{
    display:flex; align-items:center; justify-content:space-between;
    padding:22px 0 18px; border-bottom:1px solid var(--line);
    margin-bottom:22px; gap:16px; flex-wrap:wrap;
  }
  .brand{ display:flex; align-items:center; gap:10px; }
  .brand-mark{
    width:26px;height:26px;border:1.5px solid var(--accent);border-radius:6px;
    position:relative; flex:none;
  }
  .brand-mark::after{
    content:"";position:absolute; left:50%; top:5px; width:3px; height:3px;
    background:var(--accent); border-radius:50%; transform:translateX(-50%);
  }
  .brand-text{ font-weight:700; letter-spacing:.02em; font-size:15px; }
  .brand-sub{ font-size:11px; color:var(--muted-2); font-family:'JetBrains Mono',monospace; letter-spacing:.06em; text-transform:uppercase;}

  .mode-toggle{ display:flex; background:var(--panel); border:1px solid var(--line); border-radius:9px; padding:3px; }
  .mode-toggle button{
    border:none; background:transparent; color:var(--muted); padding:8px 18px;
    font-family:inherit; font-size:13px; font-weight:600; border-radius:6px; cursor:pointer;
    transition:.15s;
  }
  .mode-toggle button.active{ background:var(--accent); color:#08211d; }

  /* ---------- sub-tab bars (create section / component type) ---------- */
  .subtab-bar{ display:flex; gap:6px; margin-bottom:18px; flex-wrap:wrap; }
  .subtab-bar button{
    border:1px solid var(--line); background:var(--panel); color:var(--muted); padding:8px 16px;
    font-family:inherit; font-size:12.5px; font-weight:600; border-radius:7px; cursor:pointer; transition:.15s;
  }
  .subtab-bar button:hover{ color:var(--text); border-color:var(--muted-2); }
  .subtab-bar button.active{ background:var(--accent-dim); color:var(--accent); border-color:var(--accent); }
  .subtab-bar.small button{ padding:6px 12px; font-size:12px; }

  /* ---------- buttons ---------- */
  .btn{
    font-family:inherit; font-size:13px; font-weight:600; cursor:pointer;
    border-radius:7px; border:1px solid var(--line); background:var(--panel-2);
    color:var(--text); padding:9px 14px; transition:.15s; display:inline-flex; align-items:center; gap:6px;
  }
  .btn:hover{ border-color:var(--accent); color:var(--accent); }
  .btn-primary{ background:var(--accent); border-color:var(--accent); color:#08211d; }
  .btn-primary:hover{ filter:brightness(1.08); color:#08211d; }
  .btn-danger{ color:var(--danger); }
  .btn-danger:hover{ border-color:var(--danger); color:var(--danger); background:var(--danger-dim); }
  .btn-ghost{ background:transparent; border-color:transparent; color:var(--muted); }
  .btn-ghost:hover{ color:var(--accent); }
  .btn-sm{ padding:6px 10px; font-size:12px; border-radius:6px; }
  .btn[disabled]{ opacity:.35; cursor:not-allowed; }
  .btn[disabled]:hover{ border-color:var(--line); color:var(--text); }

  /* ---------- section header ---------- */
  .section-head{ display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; gap:12px; flex-wrap:wrap;}
  .section-title{ font-size:18px; font-weight:600; }
  .section-title small{ display:block; font-size:11px; color:var(--muted-2); font-weight:500; text-transform:uppercase; letter-spacing:.08em; margin-top:2px; font-family:'JetBrains Mono',monospace;}

  /* ---------- grid / cards ---------- */
  .grid{ display:grid; grid-template-columns:repeat(auto-fill, minmax(220px,1fr)); gap:14px; }
  .card{
    background:var(--panel); border:1px solid var(--line); border-radius:12px; padding:16px;
    display:flex; flex-direction:column; gap:10px; position:relative;
  }
  .card-new{
    display:flex; align-items:center; justify-content:center; min-height:120px;
    border:1.5px dashed var(--line); background:transparent; cursor:pointer; color:var(--muted);
    font-weight:600; font-size:13px; transition:.15s;
  }
  .card-new:hover{ border-color:var(--accent); color:var(--accent); }
  .card-title{ font-weight:600; font-size:15px; display:flex; align-items:center; gap:8px;}
  .hidden-tag{ font-size:10px; text-transform:uppercase; letter-spacing:.06em; color:var(--muted-2); border:1px solid var(--line); padding:2px 6px; border-radius:4px; font-family:'JetBrains Mono',monospace;}
  .type-tag{ font-size:10px; text-transform:uppercase; letter-spacing:.06em; color:var(--accent); border:1px solid var(--accent-dim); padding:2px 6px; border-radius:4px; font-family:'JetBrains Mono',monospace;}
  .card-meta{ font-size:12px; color:var(--muted); font-family:'JetBrains Mono',monospace; line-height:1.7;}
  .card-meta b{ color:var(--text); font-weight:500;}
  .card-actions{ display:flex; gap:6px; flex-wrap:wrap; margin-top:auto; padding-top:8px; border-top:1px solid var(--line-soft);}
  .thumb{
    width:100%; aspect-ratio:13/25; background:var(--panel-2); border-radius:8px; border:1px solid var(--line-soft);
    overflow:hidden; max-height:150px; margin:0 auto;
  }
  .thumb svg{ width:100%; height:100%; display:block; }

  /* ---------- forms ---------- */
  .field{ display:flex; flex-direction:column; gap:5px; margin-bottom:14px; }
  .field label{ font-size:11px; text-transform:uppercase; letter-spacing:.07em; color:var(--muted-2); font-weight:600; font-family:'JetBrains Mono',monospace;}
  .field input, .field select{
    background:var(--panel-2); border:1px solid var(--line); color:var(--text);
    padding:9px 11px; border-radius:7px; font-family:'JetBrains Mono',monospace; font-size:13px; outline:none; width:100%;
  }
  .field input:focus{ border-color:var(--accent); }
  .field-row{ display:grid; grid-template-columns:1fr 1fr; gap:12px; }
  .hint{ font-size:11px; color:var(--muted-2); margin-top:-2px; }

  /* ---------- modal ---------- */
  .overlay{
    position:fixed; inset:0; background:rgba(4,5,7,.7); backdrop-filter:blur(2px);
    display:flex; align-items:center; justify-content:center; z-index:50; padding:20px;
  }
  .modal{
    background:var(--panel); border:1px solid var(--line); border-radius:14px; padding:24px;
    width:100%; max-width:380px; max-height:90vh; overflow:auto;
  }
  .modal.wide{ max-width:480px; }
  .modal h3{ margin:0 0 18px; font-size:16px; }
  .modal-actions{ display:flex; justify-content:flex-end; gap:8px; margin-top:6px; }
  .picker-row{
    display:flex; align-items:center; justify-content:space-between; gap:10px; padding:10px 12px;
    border:1px solid var(--line-soft); border-radius:8px; margin-bottom:8px; background:var(--panel-2);
  }
  .picker-row .name{ font-size:13px; font-weight:600; }
  .picker-row .sub{ font-size:11px; color:var(--muted-2); font-family:'JetBrains Mono',monospace; margin-top:2px;}

  /* ---------- phone editor ---------- */
  .editor-layout{ display:grid; grid-template-columns:260px 1fr 260px; gap:20px; align-items:start; }
  @media (max-width:880px){ .editor-layout{ grid-template-columns:1fr; } }
  .panel{ background:var(--panel); border:1px solid var(--line); border-radius:12px; padding:18px; }
  .panel-title{ font-size:11px; text-transform:uppercase; letter-spacing:.08em; color:var(--muted-2); font-weight:700; margin-bottom:14px; font-family:'JetBrains Mono',monospace;}

  .canvas-toolbar{ display:flex; gap:8px; margin-bottom:14px; flex-wrap:wrap; }
  .canvas-wrap{
    background:
      linear-gradient(var(--line-soft) 1px, transparent 1px) 0 0/26px 26px,
      linear-gradient(90deg, var(--line-soft) 1px, transparent 1px) 0 0/26px 26px,
      var(--panel-2);
    border:1px solid var(--line); border-radius:10px; overflow:hidden; margin:0 auto;
    width:100%; max-width:260px; aspect-ratio:13/25; position:relative;
  }
  .canvas-wrap svg{ width:100%; height:100%; display:block; touch-action:none; }
  .canvas-caption{ text-align:center; font-size:11px; color:var(--muted-2); margin-top:10px; font-family:'JetBrains Mono',monospace;}
  .shape-el{ cursor:grab; }
  .shape-el:active{ cursor:grabbing; }
  .shape-el.selected{ stroke:var(--accent); stroke-width:2; stroke-dasharray:4 3; }

  .layer-row{
    display:flex; align-items:center; justify-content:space-between; padding:7px 9px;
    border:1px solid var(--line-soft); border-radius:7px; margin-bottom:6px; font-size:12px; cursor:pointer;
    background:var(--panel-2);
  }
  .layer-row.selected{ border-color:var(--accent); color:var(--accent); }
  .layer-row span.swatch{ width:9px;height:9px;border-radius:3px;display:inline-block;margin-right:7px; vertical-align:middle;}
  .empty-note{ color:var(--muted-2); font-size:12px; text-align:center; padding:20px 10px; }

  .prop-empty{ color:var(--muted-2); font-size:12px; line-height:1.6; }

  /* ---------- component-slot rows in phone editor ---------- */
  .slot-row{
    border:1px solid var(--line-soft); border-radius:8px; padding:10px 11px; margin-bottom:10px; background:var(--panel-2);
  }
  .slot-row .slot-label{ font-size:10px; text-transform:uppercase; letter-spacing:.06em; color:var(--muted-2); font-family:'JetBrains Mono',monospace; margin-bottom:6px;}
  .slot-row .slot-chosen{ font-size:13px; font-weight:600; margin-bottom:8px; }
  .slot-row .slot-empty{ font-size:12px; color:var(--muted-2); margin-bottom:8px; }
  .slot-row .slot-btns{ display:flex; gap:6px; flex-wrap:wrap; }
  .cam-chip{
    display:inline-flex; align-items:center; gap:6px; background:var(--panel); border:1px solid var(--line-soft);
    border-radius:6px; padding:5px 8px; font-size:12px; margin:0 6px 6px 0;
  }
  .cam-chip button{ background:none; border:none; color:var(--muted-2); cursor:pointer; font-size:13px; line-height:1; padding:0;}
  .cam-chip button:hover{ color:var(--danger); }

  /* ---------- slider + number combo ----------
     The slider is the primary, dominant control (flex:1, taller track, bigger thumb).
     The number box is a fixed, comfortably-readable size for precise typing — not tiny,
     but clearly secondary to the slider. Used ONLY for shape properties. */
  .slider-row{ display:flex; align-items:center; gap:12px; }
  .slider-row input[type="range"]{ flex:1 1 auto; min-width:70px; }
  .slider-row .slider-num{ width:72px; flex:0 0 72px; text-align:center; padding:8px 4px; }

  input[type="range"]{
    -webkit-appearance:none; appearance:none; width:100%; height:6px; border-radius:3px;
    background:var(--line); outline:none; cursor:pointer; margin:0;
  }
  input[type="range"]::-webkit-slider-thumb{
    -webkit-appearance:none; appearance:none; width:19px; height:19px; border-radius:50%;
    background:var(--accent); cursor:pointer; border:2px solid #08211d; box-shadow:0 0 0 1px var(--accent);
  }
  input[type="range"]::-moz-range-thumb{
    width:19px; height:19px; border-radius:50%; background:var(--accent); cursor:pointer;
    border:2px solid #08211d; box-shadow:0 0 0 1px var(--accent);
  }
  input[type="range"]::-moz-range-track{ background:var(--line); height:6px; border-radius:3px; }

  /* ---------- color field ---------- */
  .color-row{ display:flex; align-items:center; gap:8px; }
  input[type="color"]{
    -webkit-appearance:none; appearance:none; width:42px; height:34px; flex:none;
    border:1px solid var(--line); border-radius:7px; background:var(--panel-2); cursor:pointer; padding:2px;
  }
  input[type="color"]::-webkit-color-swatch-wrapper{ padding:0; }
  input[type="color"]::-webkit-color-swatch{ border:none; border-radius:5px; }
  input[type="color"]::-moz-color-swatch{ border:none; border-radius:5px; }
  .color-hex{ flex:1; text-transform:uppercase; }
  .preset-row{ display:flex; gap:6px; flex-wrap:wrap; margin-top:9px; }
  .preset-swatch{
    width:22px; height:22px; border-radius:6px; border:1px solid var(--line-soft); cursor:pointer;
    padding:0; transition:.15s;
  }
  .preset-swatch:hover{ transform:scale(1.15); border-color:var(--accent); }

  /* ---------- layer row extras ---------- */
  .layer-main{ display:flex; align-items:center; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; flex:1; min-width:0; }
  .layer-btns{ display:flex; gap:4px; flex:none; margin-left:8px; }
  .layer-btn{
    background:transparent; border:1px solid var(--line-soft); color:var(--muted); width:20px; height:20px;
    border-radius:4px; font-size:11px; cursor:pointer; display:flex; align-items:center; justify-content:center;
    line-height:1; padding:0;
  }
  .layer-btn:hover{ border-color:var(--accent); color:var(--accent); }
  .layer-btn:disabled{ opacity:.3; cursor:not-allowed; }
  .layer-btn:disabled:hover{ border-color:var(--line-soft); color:var(--muted); }

  /* ---------- play mode ---------- */
  .stat-bar{
    display:grid; grid-template-columns:repeat(4,1fr); gap:1px; background:var(--line);
    border:1px solid var(--line); border-radius:12px; overflow:hidden; margin-bottom:20px;
  }
  @media (max-width:700px){ .stat-bar{ grid-template-columns:repeat(2,1fr);} }
  .stat{ background:var(--panel); padding:16px 18px; }
  .stat .label{ font-size:10px; text-transform:uppercase; letter-spacing:.08em; color:var(--muted-2); font-family:'JetBrains Mono',monospace; margin-bottom:6px;}
  .stat .value{ font-size:19px; font-weight:700; font-family:'JetBrains Mono',monospace; }
  .stat .value.accent{ color:var(--accent); }

  .play-top{ display:grid; grid-template-columns:180px 1fr; gap:20px; margin-bottom:26px; }
  @media (max-width:640px){ .play-top{ grid-template-columns:1fr; } }
  .equip-box{
    background:var(--panel); border:1px solid var(--line); border-radius:12px; padding:14px;
    display:flex; flex-direction:column; align-items:center; gap:8px;
  }
  .equip-box .thumb{ max-height:none; }
  .equip-box .name{ font-size:12px; font-weight:600; text-align:center; }
  .equip-box .qual{ font-size:11px; color:var(--muted); font-family:'JetBrains Mono',monospace; }
  .tf-panel{
    background:var(--panel); border:1px solid var(--line); border-radius:12px; padding:18px;
    display:flex; flex-direction:column; justify-content:center; gap:10px;
  }
  .tf-panel .tick{ font-size:11px; color:var(--muted-2); font-family:'JetBrains Mono',monospace; }

  .two-col{ display:grid; grid-template-columns:1fr 1fr; gap:20px; }
  @media (max-width:760px){ .two-col{ grid-template-columns:1fr; } }

  .list-row{
    display:flex; align-items:center; justify-content:space-between; padding:11px 13px;
    border:1px solid var(--line-soft); border-radius:8px; margin-bottom:8px; background:var(--panel);
    gap:10px; flex-wrap:wrap;
  }
  .list-row.equipped{ border-color:var(--accent); background:rgba(94,234,212,.06); }
  .list-row .name{ font-size:13px; font-weight:600; }
  .list-row .sub{ font-size:11px; color:var(--muted-2); font-family:'JetBrains Mono',monospace; margin-top:2px;}
  .list-row .row-actions{ display:flex; gap:6px; flex-wrap:wrap; }
  .qbar{ width:64px; height:4px; background:var(--line); border-radius:2px; overflow:hidden; margin-top:6px;}
  .qbar-fill{ height:100%; background:var(--accent); }

  .comp-spec-row{
    display:flex; align-items:center; justify-content:space-between; gap:10px; padding:10px 12px;
    border:1px solid var(--line-soft); border-radius:8px; margin-bottom:8px; background:var(--panel-2);
  }
  .comp-spec-row .name{ font-size:13px; font-weight:600; }
  .comp-spec-row .specs{ font-size:11px; color:var(--muted); font-family:'JetBrains Mono',monospace; margin-top:3px; line-height:1.6;}
  .comp-spec-row .qual-tag{ font-size:11px; font-family:'JetBrains Mono',monospace; color:var(--muted); }
  .comp-spec-row .qual-tag.low{ color:var(--warn); }

  .back-link{ display:inline-flex; align-items:center; gap:5px; color:var(--muted); font-size:12px; cursor:pointer; margin-bottom:14px; font-family:'JetBrains Mono',monospace; }
  .back-link:hover{ color:var(--accent); }

  .toast{
    position:fixed; bottom:22px; left:50%; transform:translateX(-50%);
    background:var(--panel-2); border:1px solid var(--line); color:var(--text);
    padding:10px 18px; border-radius:8px; font-size:13px; z-index:100; opacity:0;
    transition:opacity .2s, transform .2s; pointer-events:none; font-family:'JetBrains Mono',monospace;
  }
  .toast.show{ opacity:1; transform:translateX(-50%) translateY(-6px); }
</style>
</head>
<body>
<div class="shell">
  <div class="topbar">
    <div class="brand">
      <div class="brand-mark"></div>
      <div>
        <div class="brand-text">Phone Sim</div>
        <div class="brand-sub">design · trade · degrade</div>
      </div>
    </div>
    <div class="mode-toggle" id="modeToggle">
      <button data-mode="create">Create</button>
      <button data-mode="play">Play</button>
    </div>
  </div>
  <div id="app"></div>
</div>
<div class="toast" id="toast"></div>

<script>
/* ==================== STATE ==================== */
const STORAGE_KEY = 'phoneSimData_v3';
let data = loadData();
let ui = {
  mode:'create', view:'list', createSection:'phones', componentTab:'battery',
  editingPhoneId:null, draftPhone:null, selectedShapeId:null,
  editingComponentId:null, draftComponent:null, draftComponentType:null,
  editingAppId:null, draftApp:null,
  componentPicker:null, renameModal:null,
  playingAccountId:null, accountModal:null,
  infoModal:null, repairConfirm:null, appsModal:null, appOpenResult:null
};

function loadData(){
  try{
    const raw = localStorage.getItem(STORAGE_KEY);
    if(raw){
      const d = JSON.parse(raw);
      if(!d.phones) d.phones = [];
      if(!d.components) d.components = [];
      if(!d.apps) d.apps = [];
      if(!d.accounts) d.accounts = [];
      if(!d.tick) d.tick = d.tick || 0;
      d.accounts.forEach(a=>{ (a.inventory||[]).forEach(i=>{ if(!i.installedApps) i.installedApps=[]; }); });
      return d;
    }
  }catch(e){}
  return { phones:[], components:[], apps:[], accounts:[], tick:0 };
}
function save(){ localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); }
function uid(){ return Math.random().toString(36).slice(2,10) + Date.now().toString(36).slice(-4); }
function getPhone(id){ return data.phones.find(p=>p.id===id); }
function getAccount(id){ return data.accounts.find(a=>a.id===id); }
function getComponent(id){ return data.components.find(c=>c.id===id); }
function getComponentsByType(type){ return data.components.filter(c=>c.type===type); }
function getApp(id){ return data.apps.find(a=>a.id===id); }
function clamp(v,min,max){ return Math.max(min, Math.min(max, v)); }
function fmt(n){ return Math.round(n*100)/100; }
function money(n){ return '$'+fmt(n).toLocaleString(); }

function toast(msg){
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  clearTimeout(toast._t);
  toast._t = setTimeout(()=>t.classList.remove('show'), 1800);
}

/* ==================== COMPONENT DEFINITIONS ==================== */
const COMPONENT_TYPES = ['battery','processor','screen','camera','storage'];
function componentLabel(type){
  return ({ battery:'Battery', processor:'Processor', screen:'Screen', camera:'Camera', storage:'Storage & RAM' })[type] || type;
}
function componentTypeHasQuality(type){ return type==='battery' || type==='screen'; }
function defaultComponentDraft(type){
  const base = { id:null, type, name:'New '+componentLabel(type), price:20 };
  switch(type){
    case 'battery': return { ...base, capacity:3000, durabilityMin:65, durabilityMax:90 };
    case 'processor': return { ...base, performance:50 };
    case 'screen': return { ...base, resolution:1080, hertz:60, brightness:500, durabilityMin:65, durabilityMax:90 };
    case 'camera': return { ...base, megapixels:12, sensorSize:1, processingQuality:50 };
    case 'storage': return { ...base, ram:8, storage:128 };
  }
}
/* Quality lost this tick: durability is rolled randomly between durabilityMin and durabilityMax
   (so wear speed varies tick to tick), then converted to a loss amount. Higher rolled durability
   = slower wear. */
function degradePerTick(durMin, durMax){
  const lo = Math.min(durMin||0, durMax||0), hi = Math.max(durMin||0, durMax||0);
  const roll = lo + Math.random() * (hi - lo);
  return clamp((100 - roll) / 20, 0, 100);
}
/* Short spec summary for cards / rows */
function componentSpecLine(c){
  switch(c.type){
    case 'battery': return `Capacity ${c.capacity} · Durability ${c.durabilityMin}–${c.durabilityMax}%`;
    case 'processor': return `Performance ${c.performance}`;
    case 'screen': return `${c.resolution}p · ${c.hertz}Hz · Brightness ${c.brightness} · Durability ${c.durabilityMin}–${c.durabilityMax}%`;
    case 'camera': return `${c.megapixels}MP · Sensor ${c.sensorSize} · Processing ${c.processingQuality}`;
    case 'storage': return `RAM ${c.ram} · Storage ${c.storage}`;
  }
}

/* ==================== APP REQUIREMENT DEFINITIONS ==================== */
const REQ_KEYS = ['batteryCapacity','processorPerformance','screenResolution','screenHertz','screenBrightness','cameraMegapixels','cameraSensorSize','cameraProcessingQuality','ram'];
const REQ_LABELS = {
  batteryCapacity:'Battery Capacity', processorPerformance:'Processor Performance',
  screenResolution:'Screen Resolution', screenHertz:'Screen Hertz', screenBrightness:'Screen Brightness',
  cameraMegapixels:'Camera Megapixels', cameraSensorSize:'Camera Sensor Size', cameraProcessingQuality:'Camera Processing Quality',
  ram:'RAM'
};
function defaultAppDraft(){
  const reqs = {};
  REQ_KEYS.forEach(k=> reqs[k] = { value:null, exact:false });
  return { id:null, name:'New App', storageSize:8, reqs };
}
/* Actual specs a phone provides, pulled live from its chosen components.
   Cameras: a phone can have several, so each metric uses the best (max) among them. */
function phoneActualSpecs(phone){
  const battery = phone.batteryId ? getComponent(phone.batteryId) : null;
  const processor = phone.processorId ? getComponent(phone.processorId) : null;
  const screen = phone.screenId ? getComponent(phone.screenId) : null;
  const cams = (phone.cameraIds||[]).map(getComponent).filter(Boolean);
  const storageComp = phone.storageId ? getComponent(phone.storageId) : null;
  return {
    batteryCapacity: battery ? battery.capacity : 0,
    processorPerformance: processor ? processor.performance : 0,
    screenResolution: screen ? screen.resolution : 0,
    screenHertz: screen ? screen.hertz : 0,
    screenBrightness: screen ? screen.brightness : 0,
    cameraMegapixels: cams.length ? Math.max(...cams.map(c=>c.megapixels)) : 0,
    cameraSensorSize: cams.length ? Math.max(...cams.map(c=>c.sensorSize)) : 0,
    cameraProcessingQuality: cams.length ? Math.max(...cams.map(c=>c.processingQuality)) : 0,
    ram: storageComp ? storageComp.ram : 0
  };
}
/* Usability % for an app on a phone:
   - blank requirement = ignored (doesn't count toward the average)
   - at exactly the requirement, that stat scores 100%; above it scales linearly (2x => 200%, no cap)
   - below the requirement it falls off twice as fast, hitting 0% at 0.5x the requirement (floored at 0%)
   - "exact or higher" requirements force the WHOLE app to 0% if the phone falls short */
function computeUsability(app, phone){
  const specs = phoneActualSpecs(phone);
  let gateFailed = false;
  const breakdown = [];
  let sum = 0, count = 0;
  REQ_KEYS.forEach(k=>{
    const req = app.reqs[k];
    if(!req || req.value===null || req.value===undefined || req.value==='') return;
    const R = parseFloat(req.value);
    if(isNaN(R) || R<=0) return;
    const A = specs[k];
    if(req.exact && A < R) gateFailed = true;
    const ratio = A / R;
    let pct = ratio>=1 ? ratio*100 : (200*ratio - 100);
    pct = Math.max(0, pct);
    breakdown.push({ label:REQ_LABELS[k], required:R, actual:A, exact:!!req.exact, pct });
    sum += pct; count++;
  });
  const usability = gateFailed ? 0 : (count ? sum/count : 100);
  return { usability, breakdown, gateFailed };
}

/* ==================== CANVAS CONST ==================== */
const CW = 260, CH = 500; // design space (viewBox units)

/* ---- polygon point math, shared by triangle / star / hexagon ---- */
function regularPolygonPoints(cx, cy, r, sides, rotationDeg){
  const rot = ((rotationDeg||0) * Math.PI) / 180;
  const pts = [];
  for(let i=0;i<sides;i++){
    const angle = rot + i * (2*Math.PI/sides) - Math.PI/2;
    pts.push((cx + r*Math.cos(angle)).toFixed(2) + ',' + (cy + r*Math.sin(angle)).toFixed(2));
  }
  return pts.join(' ');
}
function starPoints(cx, cy, outerR, innerR, points, rotationDeg){
  const rot = ((rotationDeg||0) * Math.PI) / 180;
  const step = Math.PI / points;
  const pts = [];
  for(let i=0;i<points*2;i++){
    const r = (i%2===0) ? outerR : innerR;
    const angle = rot + i*step - Math.PI/2;
    pts.push((cx + r*Math.cos(angle)).toFixed(2) + ',' + (cy + r*Math.sin(angle)).toFixed(2));
  }
  return pts.join(' ');
}

/* ==================== MODE TOGGLE ==================== */
document.getElementById('modeToggle').addEventListener('click', e=>{
  const btn = e.target.closest('button[data-mode]');
  if(!btn) return;
  ui.mode = btn.dataset.mode;
  ui.view = 'list';
  render();
});

/* ==================== RENDER DISPATCH ==================== */
function render(){
  document.querySelectorAll('#modeToggle button').forEach(b=>{
    b.classList.toggle('active', b.dataset.mode===ui.mode);
  });
  const app = document.getElementById('app');
  app.innerHTML = '';
  if(ui.mode==='create'){
    if(ui.view==='editor') app.appendChild(renderPhoneEditor());
    else if(ui.view==='componentEditor') app.appendChild(renderComponentEditor());
    else if(ui.view==='appEditor') app.appendChild(renderAppEditor());
    else app.appendChild(renderCreateList());
  } else {
    if(ui.view==='play' && ui.playingAccountId) app.appendChild(renderPlayView());
    else app.appendChild(renderAccountList());
  }
  // Always clear out any previously-mounted modal before deciding whether to show one.
  document.querySelectorAll('.overlay').forEach(o=>o.remove());
  if(ui.accountModal) document.body.appendChild(renderAccountModal());
  if(ui.componentPicker) document.body.appendChild(renderComponentPickerModal());
  if(ui.renameModal) document.body.appendChild(renderRenameModal());
  if(ui.repairConfirm) document.body.appendChild(renderRepairConfirmModal());
  else if(ui.infoModal) document.body.appendChild(renderInfoModal());
  if(ui.appOpenResult) document.body.appendChild(renderAppOpenResultModal());
  else if(ui.appsModal) document.body.appendChild(renderAppsModal());
}

/* ==================== CREATE MODE: TOP-LEVEL LIST (Phones / Components / Apps) ==================== */
function renderCreateList(){
  const wrap = document.createElement('div');

  const tabs = document.createElement('div');
  tabs.className = 'subtab-bar';
  [['phones','Phones'],['components','Components'],['apps','Apps']].forEach(([key,label])=>{
    const b = document.createElement('button');
    b.textContent = label;
    b.classList.toggle('active', ui.createSection===key);
    b.onclick = ()=>{ ui.createSection = key; render(); };
    tabs.appendChild(b);
  });
  wrap.appendChild(tabs);

  if(ui.createSection==='components'){
    wrap.appendChild(renderComponentList());
  } else if(ui.createSection==='apps'){
    wrap.appendChild(renderAppList());
  } else {
    wrap.appendChild(renderPhoneList());
  }
  return wrap;
}

/* ==================== CREATE MODE: PHONE LIST ==================== */
function renderPhoneList(){
  const wrap = document.createElement('div');
  const head = document.createElement('div');
  head.className = 'section-head';
  head.innerHTML = `<div class="section-title">Phone Designs <small>${data.phones.length} created</small></div>`;
  wrap.appendChild(head);

  const grid = document.createElement('div');
  grid.className = 'grid';

  const newCard = document.createElement('div');
  newCard.className = 'card card-new';
  newCard.style.minHeight = '190px';
  newCard.textContent = '+ Create New Phone';
  newCard.onclick = ()=> openPhoneEditor(null);
  grid.appendChild(newCard);

  data.phones.forEach(p=>{
    const inUse = data.accounts.some(a=>a.inventory.some(i=>i.phoneId===p.id));
    const card = document.createElement('div');
    card.className = 'card';
    const battery = p.batteryId ? getComponent(p.batteryId) : null;
    const screen = p.screenId ? getComponent(p.screenId) : null;
    const processor = p.processorId ? getComponent(p.processorId) : null;
    const storage = p.storageId ? getComponent(p.storageId) : null;
    const camCount = (p.cameraIds||[]).length;
    card.innerHTML = `
      <div class="thumb">${renderPhoneSVG(p,false)}</div>
      <div class="card-title">${escapeHtml(p.name)} ${!p.visible?'<span class="hidden-tag">Hidden</span>':''}</div>
      <div class="card-meta">
        Price <b>${money(p.price)}</b><br>
        Battery <b>${battery?escapeHtml(battery.name):'—'}</b><br>
        Screen <b>${screen?escapeHtml(screen.name):'—'}</b><br>
        Processor <b>${processor?escapeHtml(processor.name):'—'}</b><br>
        Storage & RAM <b>${storage?escapeHtml(storage.name):'—'}</b><br>
        Cameras <b>${camCount}</b>
      </div>
      <div class="card-actions"></div>
    `;
    const actions = card.querySelector('.card-actions');

    const editBtn = mkBtn('Edit','btn-sm', ()=>openPhoneEditor(p.id));
    const cloneBtn = mkBtn('Clone','btn-sm', ()=>clonePhone(p.id));
    const visBtn = mkBtn(p.visible?'Hide':'Show','btn-sm', ()=>toggleVisible(p.id));
    const delBtn = mkBtn('Delete','btn-sm btn-danger', ()=>deletePhone(p.id));
    if(inUse){ delBtn.disabled = true; delBtn.title = 'Owned by at least one account — hide it instead'; }
    actions.append(editBtn, cloneBtn, visBtn, delBtn);
    grid.appendChild(card);
  });

  wrap.appendChild(grid);
  return wrap;
}

function mkBtn(label, cls, onclick){
  const b = document.createElement('button');
  b.className = 'btn '+cls;
  b.textContent = label;
  b.onclick = onclick;
  return b;
}
function layerBtn(label, title, onclick, disabled){
  const b = document.createElement('button');
  b.className = 'layer-btn';
  b.textContent = label;
  b.title = title;
  b.disabled = !!disabled;
  b.onclick = onclick;
  return b;
}
function escapeHtml(s){
  return (s??'').replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

function clonePhone(id){
  const p = getPhone(id);
  const copy = JSON.parse(JSON.stringify(p));
  copy.id = uid();
  copy.name = p.name + ' Copy';
  data.phones.push(copy);
  save(); render(); toast('Phone cloned');
}
function toggleVisible(id){
  const p = getPhone(id);
  p.visible = !p.visible;
  save(); render();
}
function deletePhone(id){
  const inUse = data.accounts.some(a=>a.inventory.some(i=>i.phoneId===id));
  if(inUse){ toast('Cannot delete — owned by an account. Hide it instead.'); return; }
  if(!confirm('Delete this phone design permanently?')) return;
  data.phones = data.phones.filter(p=>p.id!==id);
  save(); render(); toast('Phone deleted');
}

/* ==================== PHONE SVG RENDER ==================== */
function shapeMarkup(s, editable){
  const sel = editable && ui.selectedShapeId===s.id ? ' selected' : '';
  const dataAttr = editable ? `class="shape-el${sel}" data-id="${s.id}"` : '';
  switch(s.type){
    case 'rect':
      return `<rect ${dataAttr} x="${s.x}" y="${s.y}" width="${s.w}" height="${s.h}" rx="${s.rx||0}" fill="${s.fill}"/>`;
    case 'circle':
      return `<circle ${dataAttr} cx="${s.cx}" cy="${s.cy}" r="${s.r}" fill="${s.fill}"/>`;
    case 'ellipse':
      return `<ellipse ${dataAttr} cx="${s.cx}" cy="${s.cy}" rx="${s.rx}" ry="${s.ry}" fill="${s.fill}"/>`;
    case 'triangle':
      return `<polygon ${dataAttr} points="${regularPolygonPoints(s.cx,s.cy,s.size,3,s.rotation)}" fill="${s.fill}"/>`;
    case 'star':
      return `<polygon ${dataAttr} points="${starPoints(s.cx,s.cy,s.outerR,s.innerR,s.points||5,s.rotation)}" fill="${s.fill}"/>`;
    case 'hexagon':
      return `<polygon ${dataAttr} points="${regularPolygonPoints(s.cx,s.cy,s.r,6,s.rotation)}" fill="${s.fill}"/>`;
    case 'line':
      return `<line ${dataAttr} x1="${s.x1}" y1="${s.y1}" x2="${s.x2}" y2="${s.y2}" stroke="${s.fill}" stroke-width="${s.strokeWidth||6}" stroke-linecap="round"/>`;
    default:
      return '';
  }
}
function renderPhoneSVG(phone, editable){
  const shapes = phone.shapes || [];
  let body = `<rect x="0" y="0" width="${CW}" height="${CH}" fill="none"/>`;
  shapes.forEach(s=>{ body += shapeMarkup(s, editable); });
  return `<svg viewBox="0 0 ${CW} ${CH}" xmlns="http://www.w3.org/2000/svg">${body}</svg>`;
}

/* ---- push a shape's current model values onto its live SVG element ---- */
function applyShapeAttrs(el, s){
  switch(s.type){
    case 'rect':
      el.setAttribute('x', s.x); el.setAttribute('y', s.y);
      el.setAttribute('width', s.w); el.setAttribute('height', s.h);
      el.setAttribute('rx', s.rx||0);
      break;
    case 'circle':
      el.setAttribute('cx', s.cx); el.setAttribute('cy', s.cy); el.setAttribute('r', s.r);
      break;
    case 'ellipse':
      el.setAttribute('cx', s.cx); el.setAttribute('cy', s.cy);
      el.setAttribute('rx', s.rx); el.setAttribute('ry', s.ry);
      break;
    case 'triangle':
      el.setAttribute('points', regularPolygonPoints(s.cx,s.cy,s.size,3,s.rotation));
      break;
    case 'star':
      el.setAttribute('points', starPoints(s.cx,s.cy,s.outerR,s.innerR,s.points||5,s.rotation));
      break;
    case 'hexagon':
      el.setAttribute('points', regularPolygonPoints(s.cx,s.cy,s.r,6,s.rotation));
      break;
    case 'line':
      el.setAttribute('x1', s.x1); el.setAttribute('y1', s.y1);
      el.setAttribute('x2', s.x2); el.setAttribute('y2', s.y2);
      el.setAttribute('stroke-width', s.strokeWidth||6);
      el.setAttribute('stroke', s.fill);
      break;
  }
  if(s.type !== 'line') el.setAttribute('fill', s.fill);
}

/* ---- live-patch a shape straight onto the canvas + layer row, no full re-render ---- */
function updateShapeLiveDOM(shape){
  const svgEl = document.querySelector('.canvas-wrap svg');
  if(svgEl){
    const el = svgEl.querySelector(`[data-id="${shape.id}"]`);
    if(el) applyShapeAttrs(el, shape);
  }
  const dp = ui.draftPhone;
  const idx = dp ? dp.shapes.findIndex(s=>s.id===shape.id) : -1;
  const main = document.querySelector(`.layer-row[data-shape-id="${shape.id}"] .layer-main`);
  if(main && idx>-1){
    main.innerHTML = `<span class="swatch" style="background:${shape.fill}"></span>${escapeHtml(shapeDisplayName(shape, idx))}`;
  }
}

/* ==================== CREATE MODE: PHONE EDITOR ==================== */
function openPhoneEditor(id){
  if(id){
    ui.draftPhone = JSON.parse(JSON.stringify(getPhone(id)));
    if(ui.draftPhone.storageId === undefined) ui.draftPhone.storageId = null;
  } else {
    ui.draftPhone = {
      id:null, name:'New Phone', price:100, visible:true, shapes:[],
      batteryId:null, processorId:null, screenId:null, storageId:null, cameraIds:[]
    };
  }
  ui.editingPhoneId = id;
  ui.selectedShapeId = null;
  ui.view = 'editor';
  render();
}

function renderPhoneEditor(){
  const dp = ui.draftPhone;
  const wrap = document.createElement('div');

  const back = document.createElement('div');
  back.className = 'back-link';
  back.textContent = '← Back to phone list';
  back.onclick = ()=>{ ui.view='list'; ui.draftPhone=null; render(); };
  wrap.appendChild(back);

  const head = document.createElement('div');
  head.className = 'section-head';
  head.innerHTML = `<div class="section-title">${ui.editingPhoneId?'Edit Phone':'New Phone'}</div>`;
  const doneBtn = mkBtn('Done — Save Phone','btn-primary', savePhoneDraft);
  head.appendChild(doneBtn);
  wrap.appendChild(head);

  const layout = document.createElement('div');
  layout.className = 'editor-layout';

  /* --- left: meta fields + components (stacked in one column) --- */
  const leftCol = document.createElement('div');

  const meta = document.createElement('div');
  meta.className = 'panel';
  meta.innerHTML = `<div class="panel-title">Details</div>`;
  meta.appendChild(field('Name','text', dp.name, v=>dp.name=v));
  meta.appendChild(field('Price ($)','number', dp.price, v=>dp.price=numOr(v,0)));
  leftCol.appendChild(meta);

  const compPanel = document.createElement('div');
  compPanel.className = 'panel';
  compPanel.style.marginTop = '16px';
  compPanel.innerHTML = `<div class="panel-title">Components</div>`;
  compPanel.appendChild(buildSingleSlotRow(dp, 'battery', 'batteryId'));
  compPanel.appendChild(buildSingleSlotRow(dp, 'processor', 'processorId'));
  compPanel.appendChild(buildSingleSlotRow(dp, 'screen', 'screenId'));
  compPanel.appendChild(buildSingleSlotRow(dp, 'storage', 'storageId'));
  compPanel.appendChild(buildCameraSlotRow(dp));
  leftCol.appendChild(compPanel);

  layout.appendChild(leftCol);

  /* --- middle: canvas --- */
  const mid = document.createElement('div');
  const canvasPanel = document.createElement('div');
  canvasPanel.className = 'panel';
  canvasPanel.innerHTML = `<div class="panel-title">Back Panel Design</div>`;
  const toolbar = document.createElement('div');
  toolbar.className = 'canvas-toolbar';
  [['rect','+ Rect'],['circle','+ Circle'],['ellipse','+ Ellipse'],['triangle','+ Triangle'],
   ['star','+ Star'],['hexagon','+ Hexagon'],['line','+ Line']].forEach(([t,label])=>{
    toolbar.appendChild(mkBtn(label,'btn-sm', ()=>addShape(t)));
  });
  canvasPanel.appendChild(toolbar);

  const canvasWrap = document.createElement('div');
  canvasWrap.className = 'canvas-wrap';
  canvasWrap.innerHTML = renderPhoneSVG(dp, true);
  canvasPanel.appendChild(canvasWrap);
  const cap = document.createElement('div');
  cap.className = 'canvas-caption';
  cap.textContent = 'Drag shapes to position them';
  canvasPanel.appendChild(cap);
  mid.appendChild(canvasPanel);
  layout.appendChild(mid);
  attachCanvasEvents(canvasWrap.querySelector('svg'));

  /* --- right: layers + properties --- */
  const right = document.createElement('div');

  const layersPanel = document.createElement('div');
  layersPanel.className = 'panel';
  layersPanel.style.marginBottom = '16px';
  layersPanel.innerHTML = `<div class="panel-title">Shapes</div>`;
  if(dp.shapes.length===0){
    const e = document.createElement('div'); e.className='empty-note'; e.textContent='No shapes yet';
    layersPanel.appendChild(e);
  }
  dp.shapes.forEach((s,idx)=>{
    const row = document.createElement('div');
    row.className = 'layer-row' + (ui.selectedShapeId===s.id?' selected':'');
    row.dataset.shapeId = s.id;
    const main = document.createElement('span');
    main.className = 'layer-main';
    main.innerHTML = `<span class="swatch" style="background:${s.fill}"></span>${escapeHtml(shapeDisplayName(s, idx))}`;
    row.appendChild(main);
    const btns = document.createElement('span');
    btns.className = 'layer-btns';
    btns.appendChild(layerBtn('↑','Move up', e=>{ e.stopPropagation(); moveShape(idx,-1); }, idx===0));
    btns.appendChild(layerBtn('↓','Move down', e=>{ e.stopPropagation(); moveShape(idx,1); }, idx===dp.shapes.length-1));
    row.appendChild(btns);
    row.addEventListener('click', ()=>{ ui.selectedShapeId = s.id; render(); });
    layersPanel.appendChild(row);
  });
  right.appendChild(layersPanel);

  const propsPanel = document.createElement('div');
  propsPanel.className = 'panel';
  propsPanel.innerHTML = `<div class="panel-title">Properties</div>`;
  const shape = dp.shapes.find(s=>s.id===ui.selectedShapeId);
  if(!shape){
    const e = document.createElement('div'); e.className='prop-empty'; e.textContent='Select a shape to edit its size, position, and color.';
    propsPanel.appendChild(e);
  } else {
    propsPanel.appendChild(buildShapeProps(shape));
    const btnRow = document.createElement('div');
    btnRow.style.cssText = 'display:flex; gap:8px; margin-top:4px; flex-wrap:wrap;';
    btnRow.appendChild(mkBtn('Rename','btn-sm', ()=>renameShape(shape.id)));
    btnRow.appendChild(mkBtn('Duplicate','btn-sm', ()=>duplicateShape(shape.id)));
    btnRow.appendChild(mkBtn('Delete Shape','btn-danger btn-sm', ()=>{
      dp.shapes = dp.shapes.filter(s=>s.id!==shape.id); ui.selectedShapeId=null; render();
    }));
    propsPanel.appendChild(btnRow);
  }
  right.appendChild(propsPanel);
  layout.appendChild(right);

  wrap.appendChild(layout);
  return wrap;
}

/* ---- single-select component slot (battery / processor / screen) ---- */
function buildSingleSlotRow(dp, type, fieldName){
  const row = document.createElement('div');
  row.className = 'slot-row';
  const label = document.createElement('div');
  label.className = 'slot-label';
  label.textContent = componentLabel(type);
  row.appendChild(label);

  const chosen = dp[fieldName] ? getComponent(dp[fieldName]) : null;
  const info = document.createElement('div');
  if(chosen){
    info.className = 'slot-chosen';
    info.textContent = chosen.name + ' — ' + money(chosen.price);
  } else {
    info.className = 'slot-empty';
    info.textContent = 'None selected';
  }
  row.appendChild(info);

  const btns = document.createElement('div');
  btns.className = 'slot-btns';
  btns.appendChild(mkBtn('Choose '+componentLabel(type),'btn-sm', ()=>{
    ui.componentPicker = { slot:type, targetField:fieldName, multi:false };
    render();
  }));
  if(chosen){
    btns.appendChild(mkBtn('Remove','btn-sm btn-danger', ()=>{
      dp[fieldName] = null; render();
    }));
  }
  row.appendChild(btns);
  return row;
}

/* ---- multi-select component slot (camera) ---- */
function buildCameraSlotRow(dp){
  const row = document.createElement('div');
  row.className = 'slot-row';
  const label = document.createElement('div');
  label.className = 'slot-label';
  label.textContent = 'Camera';
  row.appendChild(label);

  if(!dp.cameraIds || dp.cameraIds.length===0){
    const empty = document.createElement('div');
    empty.className = 'slot-empty';
    empty.textContent = 'No cameras added';
    row.appendChild(empty);
  } else {
    const chips = document.createElement('div');
    dp.cameraIds.forEach((cid, i)=>{
      const c = getComponent(cid);
      const chip = document.createElement('span');
      chip.className = 'cam-chip';
      chip.innerHTML = `<span>${escapeHtml(c?c.name:'(missing)')}</span>`;
      const rm = document.createElement('button');
      rm.textContent = '✕';
      rm.title = 'Remove';
      rm.onclick = ()=>{ dp.cameraIds.splice(i,1); render(); };
      chip.appendChild(rm);
      chips.appendChild(chip);
    });
    row.appendChild(chips);
  }

  const btns = document.createElement('div');
  btns.className = 'slot-btns';
  btns.appendChild(mkBtn('+ Add Camera Component','btn-sm', ()=>{
    ui.componentPicker = { slot:'camera', targetField:null, multi:true };
    render();
  }));
  row.appendChild(btns);
  return row;
}

/* ---- modal listing components of a type, for selecting into a phone draft ---- */
function renderComponentPickerModal(){
  const picker = ui.componentPicker;
  const dp = ui.draftPhone;
  const overlay = document.createElement('div');
  overlay.className = 'overlay';
  overlay.onclick = (e)=>{ if(e.target===overlay){ ui.componentPicker=null; render(); } };

  const modal = document.createElement('div');
  modal.className = 'modal wide';
  modal.innerHTML = `<h3>Choose ${componentLabel(picker.slot)}</h3>`;

  const list = getComponentsByType(picker.slot);
  if(list.length===0){
    const e = document.createElement('div');
    e.className = 'empty-note';
    e.textContent = `No ${componentLabel(picker.slot)} components created yet. Switch to the Components tab to make one.`;
    modal.appendChild(e);
  }
  list.forEach(c=>{
    const row = document.createElement('div');
    row.className = 'picker-row';
    row.innerHTML = `
      <div>
        <div class="name">${escapeHtml(c.name)}</div>
        <div class="sub">${componentSpecLine(c)} · ${money(c.price)}</div>
      </div>
    `;
    if(picker.multi){
      const already = dp.cameraIds.includes(c.id);
      const addBtn = mkBtn(already?'Added':'Add','btn-sm'+(already?'':' btn-primary'), ()=>{
        dp.cameraIds.push(c.id);
        render();
      });
      row.appendChild(addBtn);
    } else {
      const selectBtn = mkBtn('Select','btn-sm btn-primary', ()=>{
        dp[picker.targetField] = c.id;
        ui.componentPicker = null;
        render();
      });
      row.appendChild(selectBtn);
    }
    modal.appendChild(row);
  });

  const actions = document.createElement('div');
  actions.className = 'modal-actions';
  actions.appendChild(mkBtn(picker.multi?'Done':'Cancel','btn-ghost', ()=>{ ui.componentPicker=null; render(); }));
  modal.appendChild(actions);

  overlay.appendChild(modal);
  return overlay;
}

function field(label, type, value, onInput, inputType){
  const f = document.createElement('div');
  f.className = 'field';
  const l = document.createElement('label'); l.textContent = label;
  const i = document.createElement('input');
  i.type = inputType==='color' ? 'text' : type;
  i.value = value;
  if(type==='number') i.step = 'any';
  i.addEventListener('input', ()=> onInput(i.value));
  f.append(l,i);
  return f;
}
function numOr(v,fallback){ const n = parseFloat(v); return isNaN(n)?fallback:n; }

/* ---- slider + number combo used for every bounded numeric SHAPE property.
   Both controls update state and live-patch the canvas directly via onChange —
   neither one ever triggers a full render(), which is what used to blow away
   focus (and the scroll position) on every keystroke. ---- */
function numField(label, value, min, max, step, onChange){
  const f = document.createElement('div');
  f.className = 'field';
  const l = document.createElement('label'); l.textContent = label;
  const row = document.createElement('div');
  row.className = 'slider-row';
  const range = document.createElement('input');
  range.type = 'range'; range.min = min; range.max = max; range.step = step;
  range.value = clamp(value, min, max);
  const num = document.createElement('input');
  num.type = 'number'; num.step = step;
  num.value = fmt(value);
  num.className = 'slider-num mono';

  range.addEventListener('input', ()=>{
    num.value = range.value;
    onChange(parseFloat(range.value));
  });
  num.addEventListener('input', ()=>{
    if(num.value==='' || num.value==='-') return;
    const v = parseFloat(num.value);
    if(isNaN(v)) return;
    range.value = v; // values outside [min,max] just pin the thumb to an end
    onChange(v);
  });
  row.append(range, num);
  f.append(l, row);
  return f;
}

/* ---- color picker + hex input + quick presets, all three kept in sync ---- */
function colorField(label, value, onChange){
  const f = document.createElement('div');
  f.className = 'field';
  const l = document.createElement('label'); l.textContent = label;
  const row = document.createElement('div');
  row.className = 'color-row';
  const picker = document.createElement('input');
  picker.type = 'color';
  picker.value = /^#[0-9a-fA-F]{6}$/.test(value) ? value : '#888888';
  const hex = document.createElement('input');
  hex.type = 'text'; hex.className = 'mono color-hex'; hex.value = value; hex.maxLength = 7; hex.spellcheck = false;

  picker.addEventListener('input', ()=>{
    hex.value = picker.value;
    onChange(picker.value);
  });
  hex.addEventListener('input', ()=>{
    let v = hex.value.trim();
    if(v && v[0] !== '#') v = '#'+v;
    if(/^#[0-9a-fA-F]{6}$/.test(v)) picker.value = v;
    onChange(hex.value || '#888888');
  });
  row.append(picker, hex);
  f.append(l, row);

  const presets = ['#f2748a','#f0b458','#5eead4','#7aa2f7','#c084fc','#ffffff','#7a8290','#1c2026'];
  const swRow = document.createElement('div');
  swRow.className = 'preset-row';
  presets.forEach(c=>{
    const sw = document.createElement('button');
    sw.type = 'button';
    sw.className = 'preset-swatch';
    sw.style.background = c;
    sw.title = c;
    sw.onclick = ()=>{ picker.value=c; hex.value=c; onChange(c); };
    swRow.appendChild(sw);
  });
  f.appendChild(swRow);
  return f;
}

/* ---- properties panel content, one branch per shape type ---- */
function buildShapeProps(shape){
  const box = document.createElement('div');
  const live = ()=> updateShapeLiveDOM(shape);

  switch(shape.type){
    case 'rect':
      box.appendChild(numField('Width', shape.w, 4, 400, 1, v=>{ shape.w=v; live(); }));
      box.appendChild(numField('Height', shape.h, 4, 600, 1, v=>{ shape.h=v; live(); }));
      box.appendChild(numField('Corner Radius', shape.rx||0, 0, 200, 1, v=>{ shape.rx=v; live(); }));
      box.appendChild(numField('X Position', shape.x, -200, CW+200, 1, v=>{ shape.x=v; live(); }));
      box.appendChild(numField('Y Position', shape.y, -200, CH+200, 1, v=>{ shape.y=v; live(); }));
      break;
    case 'circle':
      box.appendChild(numField('Radius', shape.r, 2, 220, 1, v=>{ shape.r=v; live(); }));
      box.appendChild(numField('Center X', shape.cx, -80, CW+80, 1, v=>{ shape.cx=v; live(); }));
      box.appendChild(numField('Center Y', shape.cy, -80, CH+80, 1, v=>{ shape.cy=v; live(); }));
      break;
    case 'ellipse':
      box.appendChild(numField('Radius X', shape.rx, 2, 220, 1, v=>{ shape.rx=v; live(); }));
      box.appendChild(numField('Radius Y', shape.ry, 2, 300, 1, v=>{ shape.ry=v; live(); }));
      box.appendChild(numField('Center X', shape.cx, -80, CW+80, 1, v=>{ shape.cx=v; live(); }));
      box.appendChild(numField('Center Y', shape.cy, -80, CH+80, 1, v=>{ shape.cy=v; live(); }));
      break;
    case 'triangle':
      box.appendChild(numField('Size', shape.size, 4, 220, 1, v=>{ shape.size=v; live(); }));
      box.appendChild(numField('Rotation °', shape.rotation||0, 0, 360, 1, v=>{ shape.rotation=v; live(); }));
      box.appendChild(numField('Center X', shape.cx, -80, CW+80, 1, v=>{ shape.cx=v; live(); }));
      box.appendChild(numField('Center Y', shape.cy, -80, CH+80, 1, v=>{ shape.cy=v; live(); }));
      break;
    case 'star':
      box.appendChild(numField('Outer Radius', shape.outerR, 4, 200, 1, v=>{ shape.outerR=v; live(); }));
      box.appendChild(numField('Inner Radius', shape.innerR, 2, 180, 1, v=>{ shape.innerR=v; live(); }));
      box.appendChild(numField('Points', shape.points||5, 3, 12, 1, v=>{ shape.points=Math.round(v); live(); }));
      box.appendChild(numField('Rotation °', shape.rotation||0, 0, 360, 1, v=>{ shape.rotation=v; live(); }));
      box.appendChild(numField('Center X', shape.cx, -80, CW+80, 1, v=>{ shape.cx=v; live(); }));
      box.appendChild(numField('Center Y', shape.cy, -80, CH+80, 1, v=>{ shape.cy=v; live(); }));
      break;
    case 'hexagon':
      box.appendChild(numField('Radius', shape.r, 4, 200, 1, v=>{ shape.r=v; live(); }));
      box.appendChild(numField('Rotation °', shape.rotation||0, 0, 360, 1, v=>{ shape.rotation=v; live(); }));
      box.appendChild(numField('Center X', shape.cx, -80, CW+80, 1, v=>{ shape.cx=v; live(); }));
      box.appendChild(numField('Center Y', shape.cy, -80, CH+80, 1, v=>{ shape.cy=v; live(); }));
      break;
    case 'line':
      box.appendChild(numField('Thickness', shape.strokeWidth||6, 1, 40, 1, v=>{ shape.strokeWidth=v; live(); }));
      box.appendChild(numField('Start X', shape.x1, -80, CW+80, 1, v=>{ shape.x1=v; live(); }));
      box.appendChild(numField('Start Y', shape.y1, -80, CH+80, 1, v=>{ shape.y1=v; live(); }));
      box.appendChild(numField('End X', shape.x2, -80, CW+80, 1, v=>{ shape.x2=v; live(); }));
      box.appendChild(numField('End Y', shape.y2, -80, CH+80, 1, v=>{ shape.y2=v; live(); }));
      break;
  }
  box.appendChild(colorField(shape.type==='line' ? 'Line Color' : 'Fill Color', shape.fill, v=>{
    shape.fill = v || '#888888'; live();
  }));
  return box;
}

function addShape(type){
  const dp = ui.draftPhone;
  const cx = CW/2, cy = CH/2;
  let shape;
  switch(type){
    case 'rect':
      shape = { id:uid(), type:'rect', x:cx-60, y:cy-100, w:120, h:200, rx:14, fill:'#7a8290' }; break;
    case 'circle':
      shape = { id:uid(), type:'circle', cx:cx, cy:110, r:22, fill:'#1c2026' }; break;
    case 'ellipse':
      shape = { id:uid(), type:'ellipse', cx:cx, cy:110, rx:32, ry:18, fill:'#1c2026' }; break;
    case 'triangle':
      shape = { id:uid(), type:'triangle', cx:cx, cy:cy, size:50, rotation:0, fill:'#f0b458' }; break;
    case 'star':
      shape = { id:uid(), type:'star', cx:cx, cy:cy, outerR:40, innerR:18, points:5, rotation:0, fill:'#f0b458' }; break;
    case 'hexagon':
      shape = { id:uid(), type:'hexagon', cx:cx, cy:cy, r:36, rotation:0, fill:'#5eead4' }; break;
    case 'line':
      shape = { id:uid(), type:'line', x1:cx-50, y1:cy, x2:cx+50, y2:cy, strokeWidth:6, fill:'#5eead4' }; break;
    default: return;
  }
  dp.shapes.push(shape);
  ui.selectedShapeId = shape.id;
  render();
}

function duplicateShape(id){
  const dp = ui.draftPhone;
  const s = dp.shapes.find(x=>x.id===id);
  if(!s) return;
  const copy = JSON.parse(JSON.stringify(s));
  copy.id = uid();
  if(copy.name && copy.name.trim()) copy.name = copy.name.trim() + ' Copy';
  if('x' in copy) copy.x += 12;
  if('y' in copy) copy.y += 12;
  if('cx' in copy) copy.cx = clamp(copy.cx+12, 0, CW);
  if('cy' in copy) copy.cy = clamp(copy.cy+12, 0, CH);
  if('x1' in copy){ copy.x1+=12; copy.y1+=12; copy.x2+=12; copy.y2+=12; }
  dp.shapes.push(copy);
  ui.selectedShapeId = copy.id;
  render();
}

function renameShape(id){
  const dp = ui.draftPhone;
  const s = dp.shapes.find(x=>x.id===id);
  if(!s) return;
  const idx = dp.shapes.indexOf(s);
  const current = (s.name || '').trim() || shapeDisplayName(s, idx);
  ui.renameModal = { shapeId:id, value:current };
  render();
}

function renderRenameModal(){
  const rm = ui.renameModal;
  const overlay = document.createElement('div');
  overlay.className = 'overlay';
  overlay.onclick = (e)=>{ if(e.target===overlay){ ui.renameModal=null; render(); } };

  const modal = document.createElement('div');
  modal.className = 'modal';
  modal.innerHTML = `<h3>Rename Shape</h3>`;
  const f = field('Name','text', rm.value, v=>rm.value=v);
  modal.appendChild(f);

  const commit = ()=>{
    const dp = ui.draftPhone;
    const s = dp && dp.shapes.find(x=>x.id===rm.shapeId);
    if(s) s.name = rm.value.trim();
    ui.renameModal = null;
    render();
  };

  const input = f.querySelector('input');
  input.addEventListener('keydown', e=>{ if(e.key==='Enter') commit(); });
  setTimeout(()=>{ input.focus(); input.select(); }, 0);

  const actions = document.createElement('div');
  actions.className = 'modal-actions';
  actions.appendChild(mkBtn('Cancel','btn-ghost', ()=>{ ui.renameModal=null; render(); }));
  actions.appendChild(mkBtn('Save','btn-primary', commit));
  modal.appendChild(actions);

  overlay.appendChild(modal);
  return overlay;
}

function moveShape(idx, dir){
  const dp = ui.draftPhone;
  const j = idx+dir;
  if(j<0 || j>=dp.shapes.length) return;
  const tmp = dp.shapes[idx];
  dp.shapes[idx] = dp.shapes[j];
  dp.shapes[j] = tmp;
  render();
}

function shapeLabel(type){
  return ({ rect:'Rectangle', circle:'Circle', ellipse:'Ellipse', triangle:'Triangle', star:'Star', hexagon:'Hexagon', line:'Line' })[type] || type;
}
function shapeDisplayName(shape, idx){
  const custom = (shape.name || '').trim();
  return custom ? custom : `${shapeLabel(shape.type)} ${idx+1}`;
}

function savePhoneDraft(){
  const dp = ui.draftPhone;
  if(!dp.name || !dp.name.trim()){ toast('Give the phone a name'); return; }
  if(ui.editingPhoneId){
    const idx = data.phones.findIndex(p=>p.id===ui.editingPhoneId);
    data.phones[idx] = dp;
  } else {
    dp.id = uid();
    data.phones.push(dp);
  }
  save();
  ui.view = 'list';
  ui.draftPhone = null;
  render();
  toast('Phone saved');
}

/* ==================== CREATE MODE: COMPONENT LIST ==================== */
function renderComponentList(){
  const wrap = document.createElement('div');

  const typeTabs = document.createElement('div');
  typeTabs.className = 'subtab-bar small';
  COMPONENT_TYPES.forEach(t=>{
    const b = document.createElement('button');
    b.textContent = componentLabel(t);
    b.classList.toggle('active', ui.componentTab===t);
    b.onclick = ()=>{ ui.componentTab = t; render(); };
    typeTabs.appendChild(b);
  });
  wrap.appendChild(typeTabs);

  const list = getComponentsByType(ui.componentTab);

  const head = document.createElement('div');
  head.className = 'section-head';
  head.innerHTML = `<div class="section-title">${componentLabel(ui.componentTab)} Components <small>${list.length} created</small></div>`;
  wrap.appendChild(head);

  const grid = document.createElement('div');
  grid.className = 'grid';

  const newCard = document.createElement('div');
  newCard.className = 'card card-new';
  newCard.style.minHeight = '140px';
  newCard.textContent = '+ Create New '+componentLabel(ui.componentTab);
  newCard.onclick = ()=> openComponentEditor(ui.componentTab, null);
  grid.appendChild(newCard);

  list.forEach(c=>{
    const inUse = data.phones.some(p=>
      p.batteryId===c.id || p.processorId===c.id || p.screenId===c.id || p.storageId===c.id || (p.cameraIds||[]).includes(c.id)
    );
    const card = document.createElement('div');
    card.className = 'card';
    card.innerHTML = `
      <div class="card-title"><span class="type-tag">${componentLabel(c.type)}</span></div>
      <div class="card-title">${escapeHtml(c.name)}</div>
      <div class="card-meta">
        Price <b>${money(c.price)}</b><br>
        ${componentSpecLine(c)}
      </div>
      <div class="card-actions"></div>
    `;
    const actions = card.querySelector('.card-actions');
    const editBtn = mkBtn('Edit','btn-sm', ()=>openComponentEditor(c.type, c.id));
    const cloneBtn = mkBtn('Clone','btn-sm', ()=>cloneComponent(c.id));
    const delBtn = mkBtn('Delete','btn-sm btn-danger', ()=>deleteComponent(c.id));
    if(inUse){ delBtn.disabled = true; delBtn.title = 'Used by at least one phone design'; }
    actions.append(editBtn, cloneBtn, delBtn);
    grid.appendChild(card);
  });

  wrap.appendChild(grid);
  return wrap;
}

function cloneComponent(id){
  const c = getComponent(id);
  if(!c) return;
  const copy = JSON.parse(JSON.stringify(c));
  copy.id = uid();
  copy.name = c.name + ' Copy';
  data.components.push(copy);
  save(); render(); toast('Component cloned');
}

function deleteComponent(id){
  const inUse = data.phones.some(p=>
    p.batteryId===id || p.processorId===id || p.screenId===id || p.storageId===id || (p.cameraIds||[]).includes(id)
  );
  if(inUse){ toast('Cannot delete — used by a phone design. Remove it from that phone first.'); return; }
  if(!confirm('Delete this component permanently?')) return;
  data.components = data.components.filter(c=>c.id!==id);
  save(); render(); toast('Component deleted');
}

/* ==================== CREATE MODE: COMPONENT EDITOR ==================== */
function openComponentEditor(type, id){
  if(id){
    ui.draftComponent = JSON.parse(JSON.stringify(getComponent(id)));
  } else {
    ui.draftComponent = defaultComponentDraft(type);
  }
  ui.draftComponentType = type;
  ui.editingComponentId = id;
  ui.view = 'componentEditor';
  render();
}

function renderComponentEditor(){
  const dc = ui.draftComponent;
  const type = ui.draftComponentType;
  const wrap = document.createElement('div');

  const back = document.createElement('div');
  back.className = 'back-link';
  back.textContent = '← Back to '+componentLabel(type)+' list';
  back.onclick = ()=>{ ui.view='list'; ui.createSection='components'; ui.componentTab=type; ui.draftComponent=null; render(); };
  wrap.appendChild(back);

  const head = document.createElement('div');
  head.className = 'section-head';
  head.innerHTML = `<div class="section-title">${ui.editingComponentId?'Edit':'New'} ${componentLabel(type)}</div>`;
  const doneBtn = mkBtn('Done — Save Component','btn-primary', saveComponentDraft);
  head.appendChild(doneBtn);
  wrap.appendChild(head);

  const panel = document.createElement('div');
  panel.className = 'panel';
  panel.style.maxWidth = '420px';
  panel.innerHTML = `<div class="panel-title">Details</div>`;
  panel.appendChild(field('Name','text', dc.name, v=>dc.name=v));
  panel.appendChild(field('Price ($)','number', dc.price, v=>dc.price=numOr(v,0)));

  switch(type){
    case 'battery':
      panel.appendChild(field('Capacity','number', dc.capacity, v=>dc.capacity=numOr(v,0)));
      panel.appendChild(field('Durability Min (%)','number', dc.durabilityMin, v=>dc.durabilityMin=clamp(numOr(v,0),0,100)));
      panel.appendChild(field('Durability Max (%)','number', dc.durabilityMax, v=>dc.durabilityMax=clamp(numOr(v,0),0,100)));
      panel.appendChild(hintEl('Each tick, durability is rolled randomly between Min and Max, so wear speed varies. Higher durability = slower wear. Quality lost that tick ≈ (100 − rolled durability) / 20.'));
      break;
    case 'processor':
      panel.appendChild(field('Performance','number', dc.performance, v=>dc.performance=numOr(v,0)));
      break;
    case 'screen':
      panel.appendChild(field('Resolution','number', dc.resolution, v=>dc.resolution=numOr(v,0)));
      panel.appendChild(field('Hertz','number', dc.hertz, v=>dc.hertz=numOr(v,0)));
      panel.appendChild(field('Brightness','number', dc.brightness, v=>dc.brightness=numOr(v,0)));
      panel.appendChild(field('Durability Min (%)','number', dc.durabilityMin, v=>dc.durabilityMin=clamp(numOr(v,0),0,100)));
      panel.appendChild(field('Durability Max (%)','number', dc.durabilityMax, v=>dc.durabilityMax=clamp(numOr(v,0),0,100)));
      panel.appendChild(hintEl('Each tick, durability is rolled randomly between Min and Max, so wear speed varies. Higher durability = slower wear. Quality lost that tick ≈ (100 − rolled durability) / 20.'));
      break;
    case 'camera':
      panel.appendChild(field('Megapixels','number', dc.megapixels, v=>dc.megapixels=numOr(v,0)));
      panel.appendChild(field('Sensor Size','number', dc.sensorSize, v=>dc.sensorSize=numOr(v,0)));
      panel.appendChild(field('Processing Quality','number', dc.processingQuality, v=>dc.processingQuality=numOr(v,0)));
      break;
    case 'storage':
      panel.appendChild(field('RAM','number', dc.ram, v=>dc.ram=numOr(v,0)));
      panel.appendChild(field('Storage','number', dc.storage, v=>dc.storage=numOr(v,0)));
      break;
  }

  wrap.appendChild(panel);
  return wrap;
}
function hintEl(text){
  const h = document.createElement('div');
  h.className = 'hint';
  h.style.marginBottom = '14px';
  h.textContent = text;
  return h;
}

function saveComponentDraft(){
  const dc = ui.draftComponent;
  if(!dc.name || !dc.name.trim()){ toast('Give the component a name'); return; }
  if(ui.editingComponentId){
    const idx = data.components.findIndex(c=>c.id===ui.editingComponentId);
    data.components[idx] = dc;
  } else {
    dc.id = uid();
    data.components.push(dc);
  }
  save();
  ui.view = 'list';
  ui.createSection = 'components';
  ui.componentTab = dc.type;
  ui.draftComponent = null;
  render();
  toast('Component saved');
}

/* ==================== CREATE MODE: APP LIST ==================== */
function renderAppList(){
  const wrap = document.createElement('div');
  const head = document.createElement('div');
  head.className = 'section-head';
  head.innerHTML = `<div class="section-title">Apps <small>${data.apps.length} created</small></div>`;
  wrap.appendChild(head);

  const grid = document.createElement('div');
  grid.className = 'grid';

  const newCard = document.createElement('div');
  newCard.className = 'card card-new';
  newCard.style.minHeight = '120px';
  newCard.textContent = '+ Create New App';
  newCard.onclick = ()=> openAppEditor(null);
  grid.appendChild(newCard);

  data.apps.forEach(app=>{
    const reqCount = REQ_KEYS.filter(k=> app.reqs[k] && app.reqs[k].value!==null && app.reqs[k].value!=='').length;
    const inUse = data.accounts.some(a=> a.inventory.some(i=> (i.installedApps||[]).includes(app.id)));
    const card = document.createElement('div');
    card.className = 'card';
    card.innerHTML = `
      <div class="card-title">${escapeHtml(app.name)}</div>
      <div class="card-meta">
        Storage Size <b>${app.storageSize}</b><br>
        Requirements set <b>${reqCount} / ${REQ_KEYS.length}</b>
      </div>
      <div class="card-actions"></div>
    `;
    const actions = card.querySelector('.card-actions');
    const editBtn = mkBtn('Edit','btn-sm', ()=>openAppEditor(app.id));
    const cloneBtn = mkBtn('Clone','btn-sm', ()=>cloneApp(app.id));
    const delBtn = mkBtn('Delete','btn-sm btn-danger', ()=>deleteApp(app.id));
    if(inUse){ delBtn.disabled = true; delBtn.title = 'Installed on at least one owned phone'; }
    actions.append(editBtn, cloneBtn, delBtn);
    grid.appendChild(card);
  });

  wrap.appendChild(grid);
  return wrap;
}

function cloneApp(id){
  const app = getApp(id);
  if(!app) return;
  const copy = JSON.parse(JSON.stringify(app));
  copy.id = uid();
  copy.name = app.name + ' Copy';
  data.apps.push(copy);
  save(); render(); toast('App cloned');
}
function deleteApp(id){
  const inUse = data.accounts.some(a=> a.inventory.some(i=> (i.installedApps||[]).includes(id)));
  if(inUse){ toast('Cannot delete — installed on at least one owned phone.'); return; }
  if(!confirm('Delete this app permanently?')) return;
  data.apps = data.apps.filter(a=>a.id!==id);
  save(); render(); toast('App deleted');
}

/* ==================== CREATE MODE: APP EDITOR ==================== */
function openAppEditor(id){
  if(id){
    const src = getApp(id);
    ui.draftApp = JSON.parse(JSON.stringify(src));
    REQ_KEYS.forEach(k=>{ if(!ui.draftApp.reqs[k]) ui.draftApp.reqs[k] = { value:null, exact:false }; });
  } else {
    ui.draftApp = defaultAppDraft();
  }
  ui.editingAppId = id;
  ui.view = 'appEditor';
  render();
}

function renderAppEditor(){
  const da = ui.draftApp;
  const wrap = document.createElement('div');

  const back = document.createElement('div');
  back.className = 'back-link';
  back.textContent = '← Back to app list';
  back.onclick = ()=>{ ui.view='list'; ui.createSection='apps'; ui.draftApp=null; render(); };
  wrap.appendChild(back);

  const head = document.createElement('div');
  head.className = 'section-head';
  head.innerHTML = `<div class="section-title">${ui.editingAppId?'Edit App':'New App'}</div>`;
  const doneBtn = mkBtn('Done — Save App','btn-primary', saveAppDraft);
  head.appendChild(doneBtn);
  wrap.appendChild(head);

  const panel = document.createElement('div');
  panel.className = 'panel';
  panel.style.maxWidth = '460px';
  panel.innerHTML = `<div class="panel-title">Details</div>`;
  panel.appendChild(field('Name','text', da.name, v=>da.name=v));
  panel.appendChild(field('Storage Size','number', da.storageSize, v=>da.storageSize=numOr(v,0)));
  panel.appendChild(hintEl('How much phone storage this app takes up once installed — not a requirement, just its footprint.'));
  wrap.appendChild(panel);

  const reqPanel = document.createElement('div');
  reqPanel.className = 'panel';
  reqPanel.style.maxWidth = '460px';
  reqPanel.style.marginTop = '16px';
  reqPanel.innerHTML = `<div class="panel-title">Spec Requirements</div>`;
  reqPanel.appendChild(hintEl('Leave a requirement blank if it doesn\'t matter for this app. "Exact or higher" means the phone must meet or beat that number or the app can\'t be used at all.'));
  REQ_KEYS.forEach(k=>{
    reqPanel.appendChild(buildReqField(REQ_LABELS[k], da.reqs[k]));
  });
  wrap.appendChild(reqPanel);

  return wrap;
}

/* ---- a single spec-requirement row: optional number value + "exact or higher" checkbox ---- */
function buildReqField(label, reqObj){
  const wrap = document.createElement('div');
  wrap.className = 'field';
  const l = document.createElement('label'); l.textContent = label;
  const row = document.createElement('div');
  row.style.cssText = 'display:flex; align-items:center; gap:10px;';

  const input = document.createElement('input');
  input.type = 'number'; input.step = 'any';
  input.placeholder = 'blank = not required';
  input.value = (reqObj.value===null || reqObj.value===undefined) ? '' : reqObj.value;
  input.style.flex = '1';
  input.addEventListener('input', ()=>{
    reqObj.value = input.value==='' ? null : parseFloat(input.value);
  });

  const checkLabel = document.createElement('label');
  checkLabel.style.cssText = 'display:flex; align-items:center; gap:6px; font-size:11px; color:var(--muted); white-space:nowrap; text-transform:none; letter-spacing:0; font-family:inherit; font-weight:500;';
  const check = document.createElement('input');
  check.type = 'checkbox';
  check.style.cssText = 'width:auto; padding:0;';
  check.checked = !!reqObj.exact;
  check.addEventListener('change', ()=>{ reqObj.exact = check.checked; });
  checkLabel.append(check, document.createTextNode('Exact or higher'));

  row.append(input, checkLabel);
  wrap.append(l, row);
  return wrap;
}

function saveAppDraft(){
  const da = ui.draftApp;
  if(!da.name || !da.name.trim()){ toast('Give the app a name'); return; }
  if(ui.editingAppId){
    const idx = data.apps.findIndex(a=>a.id===ui.editingAppId);
    data.apps[idx] = da;
  } else {
    da.id = uid();
    data.apps.push(da);
  }
  save();
  ui.view = 'list';
  ui.createSection = 'apps';
  ui.draftApp = null;
  render();
  toast('App saved');
}

/* ---- drag handling on the design canvas ----
   canvasDragging lives outside attachCanvasEvents on purpose: renderPhoneEditor() calls
   attachCanvasEvents() again on every render, and document-level listeners added inside
   it would otherwise pile up (harmlessly inert, but wasteful) rather than being replaced. */
let canvasDragging = null; // {shape, offX, offY, dx?, dy?}

function attachCanvasEvents(svg){
  if(!svg) return;

  function svgPoint(evt){
    const pt = svg.createSVGPoint();
    pt.x = evt.clientX; pt.y = evt.clientY;
    const ctm = svg.getScreenCTM();
    if(!ctm) return {x:0,y:0};
    return pt.matrixTransform(ctm.inverse());
  }

  svg.addEventListener('pointerdown', e=>{
    const el = e.target.closest('.shape-el');
    if(!el) return;
    const id = el.dataset.id;
    const shape = ui.draftPhone.shapes.find(s=>s.id===id);
    if(!shape) return;
    ui.selectedShapeId = id;
    const p = svgPoint(e);
    if(shape.type==='rect'){
      canvasDragging = { shape, offX: p.x - shape.x, offY: p.y - shape.y };
    } else if(shape.type==='line'){
      canvasDragging = { shape, offX: p.x - shape.x1, offY: p.y - shape.y1, dx: shape.x2-shape.x1, dy: shape.y2-shape.y1 };
    } else {
      canvasDragging = { shape, offX: p.x - shape.cx, offY: p.y - shape.cy };
    }
    svg.setPointerCapture(e.pointerId);
    render(); // to show selection highlight
    // re-grab svg reference after render rebuilt it
  });
}

document.addEventListener('pointermove', e=>{
  if(!canvasDragging) return;
  const liveSvg = document.querySelector('.canvas-wrap svg');
  if(!liveSvg) return;
  const pt = liveSvg.createSVGPoint();
  pt.x = e.clientX; pt.y = e.clientY;
  const ctm = liveSvg.getScreenCTM();
  if(!ctm) return;
  const p = pt.matrixTransform(ctm.inverse());
  const s = canvasDragging.shape;
  if(s.type==='rect'){
    s.x = clamp(p.x - canvasDragging.offX, -s.w, CW);
    s.y = clamp(p.y - canvasDragging.offY, -s.h, CH);
  } else if(s.type==='line'){
    const nx1 = clamp(p.x - canvasDragging.offX, -80, CW+80);
    const ny1 = clamp(p.y - canvasDragging.offY, -80, CH+80);
    s.x1 = nx1; s.y1 = ny1; s.x2 = nx1 + canvasDragging.dx; s.y2 = ny1 + canvasDragging.dy;
  } else {
    s.cx = clamp(p.x - canvasDragging.offX, 0, CW);
    s.cy = clamp(p.y - canvasDragging.offY, 0, CH);
  }
  const el = liveSvg.querySelector(`[data-id="${s.id}"]`);
  if(el) applyShapeAttrs(el, s);
});

document.addEventListener('pointerup', ()=>{
  if(canvasDragging){ canvasDragging = null; render(); }
});

/* ==================== PLAY MODE: ACCOUNT LIST ==================== */
function renderAccountList(){
  const wrap = document.createElement('div');
  const head = document.createElement('div');
  head.className = 'section-head';
  head.innerHTML = `<div class="section-title">Accounts <small>${data.accounts.length} players</small></div>`;
  const tf = mkBtn('⏭ Time Forward','btn', timeForward);
  head.appendChild(tf);
  wrap.appendChild(head);

  const grid = document.createElement('div');
  grid.className = 'grid';

  const newCard = document.createElement('div');
  newCard.className = 'card card-new';
  newCard.style.minHeight = '120px';
  newCard.textContent = '+ Create New Account';
  newCard.onclick = ()=>{ ui.accountModal = { id:null, name:'', salary:50, money:500 }; render(); };
  grid.appendChild(newCard);

  data.accounts.forEach(a=>{
    const netWorth = accountNetWorth(a);
    const card = document.createElement('div');
    card.className = 'card';
    card.innerHTML = `
      <div class="card-title">${escapeHtml(a.name)}</div>
      <div class="card-meta">
        Salary / tick <b>${money(a.salary)}</b><br>
        Money <b>${money(a.money)}</b><br>
        Net Worth <b>${money(netWorth)}</b><br>
        Items <b>${a.inventory.length}</b>
      </div>
      <div class="card-actions"></div>
    `;
    const actions = card.querySelector('.card-actions');
    actions.append(
      mkBtn('Play','btn-sm btn-primary', ()=>{ ui.playingAccountId=a.id; ui.view='play'; render(); }),
      mkBtn('Edit','btn-sm', ()=>{ ui.accountModal = { id:a.id, name:a.name, salary:a.salary, money:a.money }; render(); }),
      mkBtn('Delete','btn-sm btn-danger', ()=>deleteAccount(a.id))
    );
    grid.appendChild(card);
  });

  wrap.appendChild(grid);
  return wrap;
}

/* ---- quality helpers: only battery + screen contribute; no component of either type = 100% ---- */
function itemQualityParts(item, phone){
  const parts = [];
  if(phone.batteryId) parts.push(item.batteryQuality==null?100:item.batteryQuality);
  if(phone.screenId) parts.push(item.screenQuality==null?100:item.screenQuality);
  return parts;
}
function itemAvgQuality(item, phone){
  const parts = itemQualityParts(item, phone);
  if(parts.length===0) return 100;
  return parts.reduce((a,b)=>a+b,0) / parts.length;
}

function accountInventoryValue(a){
  return a.inventory.reduce((sum,item)=>{
    const p = getPhone(item.phoneId);
    if(!p) return sum;
    return sum + (itemAvgQuality(item,p)/100) * p.price;
  },0);
}
function accountNetWorth(a){ return a.money + accountInventoryValue(a); }

/* ---- storage / installed-app helpers. Apps live on the inventory item itself,
   so they persist whether or not the phone is currently equipped. ---- */
function itemInstalledApps(item){
  if(!item.installedApps) item.installedApps = [];
  return item.installedApps;
}
function itemUsedStorage(item){
  return itemInstalledApps(item).reduce((sum,aid)=>{
    const app = getApp(aid);
    return sum + (app ? app.storageSize : 0);
  },0);
}
function itemTotalStorage(phone){
  const sc = phone && phone.storageId ? getComponent(phone.storageId) : null;
  return sc ? sc.storage : 0;
}

function deleteAccount(id){
  if(!confirm('Delete this account and all its inventory?')) return;
  data.accounts = data.accounts.filter(a=>a.id!==id);
  if(ui.playingAccountId===id){ ui.playingAccountId=null; ui.view='list'; }
  save(); render(); toast('Account deleted');
}

function renderAccountModal(){
  const m = ui.accountModal;
  const overlay = document.createElement('div');
  overlay.className = 'overlay';
  overlay.onclick = (e)=>{ if(e.target===overlay){ ui.accountModal=null; render(); } };

  const modal = document.createElement('div');
  modal.className = 'modal';
  modal.innerHTML = `<h3>${m.id?'Edit Account':'New Account'}</h3>`;
  modal.appendChild(field('Name','text', m.name, v=>m.name=v));
  modal.appendChild(field('Salary per Tick ($)','number', m.salary, v=>m.salary=numOr(v,0)));
  modal.appendChild(field(m.id?'Money ($)':'Starting Money ($)','number', m.money, v=>m.money=numOr(v,0)));

  const actions = document.createElement('div');
  actions.className = 'modal-actions';
  actions.appendChild(mkBtn('Cancel','btn-ghost', ()=>{ ui.accountModal=null; render(); }));
  actions.appendChild(mkBtn(m.id?'Save':'Create','btn-primary', ()=>{
    if(!m.name || !m.name.trim()){ toast('Give the account a name'); return; }
    if(m.id){
      const acc = getAccount(m.id);
      acc.name = m.name; acc.salary = m.salary; acc.money = m.money;
    } else {
      data.accounts.push({ id:uid(), name:m.name, salary:m.salary, money:m.money, inventory:[], equippedIid:null });
    }
    save();
    ui.accountModal = null;
    render();
    toast('Account saved');
  }));
  modal.appendChild(actions);
  overlay.appendChild(modal);
  return overlay;
}

/* ==================== PLAY MODE: PLAY VIEW ==================== */
function renderPlayView(){
  const a = getAccount(ui.playingAccountId);
  const wrap = document.createElement('div');
  if(!a){ ui.view='list'; return wrap; }

  const back = document.createElement('div');
  back.className = 'back-link';
  back.textContent = '← Back to accounts';
  back.onclick = ()=>{ ui.view='list'; ui.playingAccountId=null; render(); };
  wrap.appendChild(back);

  const head = document.createElement('div');
  head.className = 'section-head';
  head.innerHTML = `<div class="section-title">${escapeHtml(a.name)} <small>tick ${data.tick}</small></div>`;
  wrap.appendChild(head);

  const invVal = accountInventoryValue(a);
  const stats = document.createElement('div');
  stats.className = 'stat-bar';
  stats.innerHTML = `
    <div class="stat"><div class="label">Salary / Tick</div><div class="value">${money(a.salary)}</div></div>
    <div class="stat"><div class="label">Current Money</div><div class="value">${money(a.money)}</div></div>
    <div class="stat"><div class="label">Inventory Value</div><div class="value">${money(invVal)}</div></div>
    <div class="stat"><div class="label">Net Worth</div><div class="value accent">${money(a.money+invVal)}</div></div>
  `;
  wrap.appendChild(stats);

  const top = document.createElement('div');
  top.className = 'play-top';

  const equipped = a.inventory.find(i=>i.iid===a.equippedIid);
  const equipBox = document.createElement('div');
  equipBox.className = 'equip-box';
  if(equipped){
    const p = getPhone(equipped.phoneId);
    const thumb = document.createElement('div');
    thumb.className = 'thumb';
    thumb.style.cssText = 'width:100px; cursor:pointer;';
    thumb.title = 'Open installed apps';
    thumb.innerHTML = renderPhoneSVG(p,false);
    thumb.onclick = ()=>{ ui.appsModal = { accId:a.id, iid:equipped.iid, mode:'installed' }; render(); };
    const name = document.createElement('div'); name.className='name'; name.textContent = p.name;
    const qual = document.createElement('div'); qual.className='qual'; qual.textContent = fmt(itemAvgQuality(equipped,p))+'% quality';
    const tapHint = document.createElement('div');
    tapHint.className = 'qual'; tapHint.style.color = 'var(--accent)'; tapHint.textContent = 'Tap to view apps';
    equipBox.append(thumb, name, qual, tapHint);
  } else {
    equipBox.innerHTML = `<div class="empty-note">No phone equipped</div>`;
  }
  top.appendChild(equipBox);

  const tf = document.createElement('div');
  tf.className = 'tf-panel';
  tf.appendChild(mkBtn('⏭ Time Forward','btn-primary', timeForward));
  const tick = document.createElement('div');
  tick.className = 'tick';
  tick.textContent = 'Advances salary for every account and wears battery/screen quality.';
  tf.appendChild(tick);
  top.appendChild(tf);

  wrap.appendChild(top);

  const cols = document.createElement('div');
  cols.className = 'two-col';

  /* Inventory */
  const invPanel = document.createElement('div');
  invPanel.innerHTML = `<div class="panel-title" style="margin-bottom:10px;">Inventory</div>`;
  if(a.inventory.length===0){
    const e = document.createElement('div'); e.className='empty-note'; e.textContent='No items owned';
    invPanel.appendChild(e);
  }
  a.inventory.forEach(item=>{
    const p = getPhone(item.phoneId);
    if(!p) return;
    const pct = clamp(itemAvgQuality(item,p),0,100);
    const isEquipped = a.equippedIid===item.iid;
    const row = document.createElement('div');
    row.className = 'list-row' + (isEquipped ? ' equipped':'');
    row.innerHTML = `
      <div>
        <div class="name">${escapeHtml(p.name)} ${isEquipped?'· equipped':''}</div>
        <div class="qbar"><div class="qbar-fill" style="width:${pct}%"></div></div>
        <div class="sub">${fmt(pct)}% quality · ${money((pct/100)*p.price)}</div>
      </div>
    `;
    const actionsWrap = document.createElement('div');
    actionsWrap.className = 'row-actions';
    actionsWrap.appendChild(mkBtn(isEquipped?'Unequip':'Equip','btn-sm'+(isEquipped?'':' btn-primary'), ()=>{
      a.equippedIid = isEquipped ? null : item.iid;
      save(); render();
    }));
    actionsWrap.appendChild(mkBtn('More Info','btn-sm', ()=>{
      ui.infoModal = { accId:a.id, iid:item.iid };
      render();
    }));
    actionsWrap.appendChild(mkBtn('Delete','btn-sm btn-danger', ()=>deleteInventoryItem(a.id, item.iid)));
    row.appendChild(actionsWrap);
    invPanel.appendChild(row);
  });
  cols.appendChild(invPanel);

  /* Shop */
  const shopPanel = document.createElement('div');
  shopPanel.innerHTML = `<div class="panel-title" style="margin-bottom:10px;">Shop</div>`;
  const shopItems = data.phones.filter(p=>p.visible);
  if(shopItems.length===0){
    const e = document.createElement('div'); e.className='empty-note'; e.textContent='No phones for sale';
    shopPanel.appendChild(e);
  }
  shopItems.forEach(p=>{
    const camCount = (p.cameraIds||[]).length;
    const parts = [];
    if(p.batteryId) parts.push('Battery');
    if(p.screenId) parts.push('Screen');
    if(p.processorId) parts.push('Processor');
    if(p.storageId) parts.push('Storage & RAM');
    if(camCount) parts.push(camCount+' Camera'+(camCount>1?'s':''));
    const row = document.createElement('div');
    row.className = 'list-row';
    row.innerHTML = `
      <div>
        <div class="name">${escapeHtml(p.name)}</div>
        <div class="sub">${parts.length?parts.join(' · '):'No components'}</div>
      </div>
    `;
    const buyBtn = mkBtn(money(p.price),'btn-sm btn-primary', ()=>buyPhone(a.id,p.id));
    if(a.money < p.price) buyBtn.disabled = true;
    row.appendChild(buyBtn);
    shopPanel.appendChild(row);
  });
  cols.appendChild(shopPanel);

  wrap.appendChild(cols);
  return wrap;
}

function buyPhone(accId, phoneId){
  const a = getAccount(accId), p = getPhone(phoneId);
  if(!a || !p) return;
  if(a.money < p.price){ toast('Not enough money'); return; }
  a.money -= p.price;
  a.inventory.push({
    iid:uid(), phoneId:p.id,
    batteryQuality: p.batteryId ? 100 : null,
    screenQuality: p.screenId ? 100 : null,
    installedApps: []
  });
  save(); render(); toast('Purchased '+p.name);
}

function deleteInventoryItem(accId, iid){
  const a = getAccount(accId);
  if(!a) return;
  if(!confirm('Remove this phone from inventory permanently?')) return;
  a.inventory = a.inventory.filter(i=>i.iid!==iid);
  if(a.equippedIid===iid) a.equippedIid = null;
  save(); render(); toast('Item deleted');
}

/* ==================== PLAY MODE: MORE INFO MODAL ==================== */
function renderInfoModal(){
  const { accId, iid } = ui.infoModal;
  const a = getAccount(accId);
  const item = a ? a.inventory.find(i=>i.iid===iid) : null;
  const overlay = document.createElement('div');
  overlay.className = 'overlay';
  overlay.onclick = (e)=>{ if(e.target===overlay){ ui.infoModal=null; render(); } };

  const modal = document.createElement('div');
  modal.className = 'modal wide';

  if(!item){
    modal.innerHTML = `<h3>Item not found</h3>`;
  } else {
    const p = getPhone(item.phoneId);
    modal.innerHTML = `<h3>${escapeHtml(p ? p.name : 'Unknown phone')}</h3>`;

    if(p){
      const battery = p.batteryId ? getComponent(p.batteryId) : null;
      const screen = p.screenId ? getComponent(p.screenId) : null;
      const processor = p.processorId ? getComponent(p.processorId) : null;
      const storageComp = p.storageId ? getComponent(p.storageId) : null;
      const cameras = (p.cameraIds||[]).map(getComponent).filter(Boolean);

      if(battery) modal.appendChild(buildInfoRow('Battery', battery, item.batteryQuality, ()=>openRepair(accId,iid,'battery')));
      if(screen) modal.appendChild(buildInfoRow('Screen', screen, item.screenQuality, ()=>openRepair(accId,iid,'screen')));
      if(processor) modal.appendChild(buildInfoRow('Processor', processor, null, null));
      if(storageComp){
        modal.appendChild(buildInfoRow('Storage & RAM', storageComp, null, null));
        const used = itemUsedStorage(item);
        const total = storageComp.storage;
        const storageRow = document.createElement('div');
        storageRow.className = 'comp-spec-row';
        storageRow.innerHTML = `
          <div>
            <div class="name">Storage Used</div>
            <div class="specs">${used} / ${total} used · ${Math.max(0,total-used)} left</div>
          </div>
        `;
        modal.appendChild(storageRow);
      }
      cameras.forEach((cam,i)=> modal.appendChild(buildInfoRow('Camera '+(i+1), cam, null, null)));

      if(!battery && !screen && !processor && !storageComp && cameras.length===0){
        const e = document.createElement('div'); e.className='empty-note'; e.textContent='No components on this phone';
        modal.appendChild(e);
      }
    }
  }

  const actions = document.createElement('div');
  actions.className = 'modal-actions';
  actions.appendChild(mkBtn('Close','btn-ghost', ()=>{ ui.infoModal=null; render(); }));
  modal.appendChild(actions);

  overlay.appendChild(modal);
  return overlay;
}
function buildInfoRow(slotLabel, component, quality, onRepair){
  const row = document.createElement('div');
  row.className = 'comp-spec-row';
  const left = document.createElement('div');
  left.innerHTML = `
    <div class="name">${slotLabel}: ${escapeHtml(component.name)}</div>
    <div class="specs">${componentSpecLine(component)} · ${money(component.price)}</div>
  `;
  row.appendChild(left);

  if(quality!=null){
    const right = document.createElement('div');
    right.style.cssText = 'display:flex; flex-direction:column; align-items:flex-end; gap:6px;';
    const q = document.createElement('div');
    q.className = 'qual-tag' + (quality<90?' low':'');
    q.textContent = fmt(quality)+'% quality';
    right.appendChild(q);
    if(quality<90){
      right.appendChild(mkBtn('Repair','btn-sm btn-primary', onRepair));
    }
    row.appendChild(right);
  }
  return row;
}
function openRepair(accId, iid, slot){
  ui.repairConfirm = { accId, iid, slot };
  render();
}

/* ==================== PLAY MODE: REPAIR CONFIRM MODAL ==================== */
function repairCost(item, phone, slot){
  const comp = slot==='battery' ? getComponent(phone.batteryId) : getComponent(phone.screenId);
  if(!comp) return 0;
  const quality = slot==='battery' ? (item.batteryQuality??100) : (item.screenQuality??100);
  const missingFrac = clamp((100-quality)/100, 0, 1);
  return Math.round(missingFrac * comp.price * 100) / 100;
}
function renderRepairConfirmModal(){
  const { accId, iid, slot } = ui.repairConfirm;
  const a = getAccount(accId);
  const item = a ? a.inventory.find(i=>i.iid===iid) : null;
  const overlay = document.createElement('div');
  overlay.className = 'overlay';
  overlay.onclick = (e)=>{ if(e.target===overlay){ ui.repairConfirm=null; render(); } };

  const modal = document.createElement('div');
  modal.className = 'modal';

  if(!item){
    modal.innerHTML = `<h3>Item not found</h3>`;
  } else {
    const p = getPhone(item.phoneId);
    const comp = slot==='battery' ? getComponent(p.batteryId) : getComponent(p.screenId);
    const cost = repairCost(item, p, slot);
    const quality = slot==='battery' ? item.batteryQuality : item.screenQuality;
    modal.innerHTML = `
      <h3>Repair ${componentLabel(slot)}</h3>
      <div class="hint" style="margin-bottom:12px;">
        ${escapeHtml(comp?comp.name:'Component')} is at ${fmt(quality)}% quality.<br>
        Repairing restores it to 100%.
      </div>
      <div class="stat" style="border:1px solid var(--line); border-radius:10px; margin-bottom:8px;">
        <div class="label">Repair Cost</div>
        <div class="value accent">${money(cost)}</div>
      </div>
    `;
  }

  const actions = document.createElement('div');
  actions.className = 'modal-actions';
  actions.appendChild(mkBtn('Cancel','btn-ghost', ()=>{ ui.repairConfirm=null; render(); }));
  if(item){
    actions.appendChild(mkBtn('Confirm Repair','btn-primary', ()=>confirmRepair(accId, iid, slot)));
  }
  modal.appendChild(actions);

  overlay.appendChild(modal);
  return overlay;
}
function confirmRepair(accId, iid, slot){
  const a = getAccount(accId);
  const item = a ? a.inventory.find(i=>i.iid===iid) : null;
  if(!a || !item){ ui.repairConfirm=null; render(); return; }
  const p = getPhone(item.phoneId);
  const cost = repairCost(item, p, slot);
  if(a.money < cost){ toast('Not enough money to repair'); return; }
  a.money -= cost;
  if(slot==='battery') item.batteryQuality = 100;
  else item.screenQuality = 100;
  save();
  ui.repairConfirm = null;
  render();
  toast('Repaired for '+money(cost));
}

/* ==================== PLAY MODE: INSTALLED APPS / APP LIBRARY MODAL ==================== */
function renderAppsModal(){
  const { accId, iid, mode } = ui.appsModal;
  const a = getAccount(accId);
  const item = a ? a.inventory.find(i=>i.iid===iid) : null;
  const overlay = document.createElement('div');
  overlay.className = 'overlay';
  overlay.onclick = (e)=>{ if(e.target===overlay){ ui.appsModal=null; render(); } };

  const modal = document.createElement('div');
  modal.className = 'modal wide';

  if(!item){
    modal.innerHTML = `<h3>Phone not found</h3>`;
  } else {
    const p = getPhone(item.phoneId);
    const total = itemTotalStorage(p);
    const used = itemUsedStorage(item);
    const installed = itemInstalledApps(item);

    if(mode==='library'){
      modal.innerHTML = `<h3>App Library</h3>`;
      const backRow = document.createElement('div');
      backRow.className = 'back-link';
      backRow.style.marginBottom = '12px';
      backRow.textContent = '← Back to Installed Apps';
      backRow.onclick = ()=>{ ui.appsModal.mode='installed'; render(); };
      modal.appendChild(backRow);

      if(data.apps.length===0){
        const e = document.createElement('div'); e.className='empty-note'; e.textContent='No apps created yet — head to Create → Apps.';
        modal.appendChild(e);
      }
      data.apps.forEach(app=>{
        const isInstalled = installed.includes(app.id);
        const row = document.createElement('div');
        row.className = 'picker-row';
        row.innerHTML = `
          <div>
            <div class="name">${escapeHtml(app.name)}</div>
            <div class="sub">Storage Size ${app.storageSize}</div>
          </div>
        `;
        if(isInstalled){
          const tag = mkBtn('Installed','btn-sm', null);
          tag.disabled = true;
          row.appendChild(tag);
        } else {
          row.appendChild(mkBtn('Install','btn-sm btn-primary', ()=>installApp(accId,iid,app.id)));
        }
        modal.appendChild(row);
      });
    } else {
      modal.innerHTML = `<h3>Installed Apps</h3>`;
      const storageRow = document.createElement('div');
      storageRow.style.cssText = 'margin-bottom:14px;';
      storageRow.innerHTML = `
        <div class="hint" style="margin-bottom:6px;">Storage: ${used} / ${total} used${total?` · ${Math.max(0,total-used)} left`:''}</div>
        <div class="qbar" style="width:100%;"><div class="qbar-fill" style="width:${total?clamp((used/total)*100,0,100):0}%"></div></div>
      `;
      modal.appendChild(storageRow);

      if(installed.length===0){
        const e = document.createElement('div'); e.className='empty-note'; e.textContent='No apps installed yet';
        modal.appendChild(e);
      }
      installed.forEach(appId=>{
        const app = getApp(appId);
        if(!app) return;
        const row = document.createElement('div');
        row.className = 'picker-row';
        row.innerHTML = `
          <div>
            <div class="name">${escapeHtml(app.name)}</div>
            <div class="sub">Storage Size ${app.storageSize}</div>
          </div>
        `;
        const btns = document.createElement('div');
        btns.style.cssText = 'display:flex; gap:6px;';
        btns.appendChild(mkBtn('Open','btn-sm btn-primary', ()=>openApp(accId,iid,app.id)));
        btns.appendChild(mkBtn('Uninstall','btn-sm btn-danger', ()=>uninstallApp(accId,iid,app.id)));
        row.appendChild(btns);
        modal.appendChild(row);
      });

      const libBtn = mkBtn('📱 App Library','btn', ()=>{ ui.appsModal.mode='library'; render(); });
      libBtn.style.marginTop = '10px';
      libBtn.style.width = '100%';
      libBtn.style.justifyContent = 'center';
      modal.appendChild(libBtn);
    }
  }

  const actions = document.createElement('div');
  actions.className = 'modal-actions';
  actions.appendChild(mkBtn('Close','btn-ghost', ()=>{ ui.appsModal=null; render(); }));
  modal.appendChild(actions);

  overlay.appendChild(modal);
  return overlay;
}

function installApp(accId, iid, appId){
  const a = getAccount(accId);
  const item = a ? a.inventory.find(i=>i.iid===iid) : null;
  if(!item) return;
  const p = getPhone(item.phoneId);
  const app = getApp(appId);
  if(!p || !app) return;
  const total = itemTotalStorage(p);
  const used = itemUsedStorage(item);
  if(total<=0){ toast('This phone has no storage — add a Storage & RAM component'); return; }
  if(used + app.storageSize > total){ toast('Not enough storage'); return; }
  itemInstalledApps(item).push(appId);
  save(); render(); toast('Installed '+app.name);
}
function uninstallApp(accId, iid, appId){
  const a = getAccount(accId);
  const item = a ? a.inventory.find(i=>i.iid===iid) : null;
  if(!item) return;
  item.installedApps = itemInstalledApps(item).filter(id=>id!==appId);
  save(); render(); toast('Uninstalled');
}
function openApp(accId, iid, appId){
  const a = getAccount(accId);
  const item = a ? a.inventory.find(i=>i.iid===iid) : null;
  const p = item ? getPhone(item.phoneId) : null;
  const app = getApp(appId);
  if(!p || !app) return;
  const result = computeUsability(app, p);
  ui.appOpenResult = { appName: app.name, usability: result.usability, breakdown: result.breakdown, gateFailed: result.gateFailed };
  render();
}

function renderAppOpenResultModal(){
  const r = ui.appOpenResult;
  const overlay = document.createElement('div');
  overlay.className = 'overlay';
  overlay.onclick = (e)=>{ if(e.target===overlay){ ui.appOpenResult=null; render(); } };

  const modal = document.createElement('div');
  modal.className = 'modal';
  modal.innerHTML = `<h3>${escapeHtml(r.appName)}</h3>`;

  const big = document.createElement('div');
  big.style.cssText = 'text-align:center; margin:6px 0 18px;';
  const color = r.usability<=0 ? 'var(--danger)' : (r.usability<100 ? 'var(--warn)' : 'var(--accent)');
  big.innerHTML = `
    <div style="font-size:36px; font-weight:700; font-family:'JetBrains Mono',monospace; color:${color};">${fmt(r.usability)}%</div>
    <div class="hint">Usability</div>
  `;
  modal.appendChild(big);

  if(r.gateFailed){
    const warn = document.createElement('div');
    warn.className = 'hint';
    warn.style.cssText = 'color:var(--danger); margin-bottom:12px;';
    warn.textContent = 'An "exact or higher" requirement was not met, so usability is forced to 0%.';
    modal.appendChild(warn);
  }

  if(r.breakdown.length===0){
    const e = document.createElement('div'); e.className='empty-note'; e.textContent='This app has no spec requirements.';
    modal.appendChild(e);
  }
  r.breakdown.forEach(b=>{
    const row = document.createElement('div');
    row.className = 'comp-spec-row';
    row.innerHTML = `
      <div>
        <div class="name">${escapeHtml(b.label)}${b.exact?' <span class="hint" style="display:inline;">(exact or higher)</span>':''}</div>
        <div class="specs">Required ${fmt(b.required)} · Phone has ${fmt(b.actual)}</div>
      </div>
      <div class="qual-tag${b.pct<100?' low':''}">${fmt(b.pct)}%</div>
    `;
    modal.appendChild(row);
  });

  const actions = document.createElement('div');
  actions.className = 'modal-actions';
  actions.appendChild(mkBtn('Close','btn-primary', ()=>{ ui.appOpenResult=null; render(); }));
  modal.appendChild(actions);

  overlay.appendChild(modal);
  return overlay;
}

/* ==================== TIME FORWARD ==================== */
function timeForward(){
  data.tick += 1;
  data.accounts.forEach(a=>{
    a.money += a.salary;
    // Only the currently-equipped phone wears down — unused inventory is untouched.
    const item = a.inventory.find(i=>i.iid===a.equippedIid);
    if(!item) return;
    const p = getPhone(item.phoneId);
    if(!p) return;
    if(p.batteryId){
      const battery = getComponent(p.batteryId);
      const loss = battery ? degradePerTick(battery.durabilityMin, battery.durabilityMax) : 0;
      item.batteryQuality = clamp((item.batteryQuality??100) - loss, 0, 100);
    }
    if(p.screenId){
      const screen = getComponent(p.screenId);
      const loss = screen ? degradePerTick(screen.durabilityMin, screen.durabilityMax) : 0;
      item.screenQuality = clamp((item.screenQuality??100) - loss, 0, 100);
    }
  });
  save(); render(); toast('Time advanced → tick '+data.tick);
}

/* ==================== KEYBOARD SHORTCUTS ==================== */
document.addEventListener('keydown', e=>{
  if(e.key==='Escape'){
    if(ui.appOpenResult){ ui.appOpenResult=null; render(); return; }
    if(ui.appsModal){ ui.appsModal=null; render(); return; }
    if(ui.renameModal){ ui.renameModal=null; render(); return; }
    if(ui.repairConfirm){ ui.repairConfirm=null; render(); return; }
    if(ui.infoModal){ ui.infoModal=null; render(); return; }
    if(ui.componentPicker){ ui.componentPicker=null; render(); return; }
    if(ui.accountModal){ ui.accountModal=null; render(); return; }
    if(ui.selectedShapeId){ ui.selectedShapeId=null; render(); return; }
  }
  if((e.key==='Delete' || e.key==='Backspace') && ui.mode==='create' && ui.view==='editor' && ui.selectedShapeId){
    const tag = (e.target && e.target.tagName || '').toLowerCase();
    if(tag==='input' || tag==='textarea') return; // never hijack typing
    const dp = ui.draftPhone;
    dp.shapes = dp.shapes.filter(s=>s.id!==ui.selectedShapeId);
    ui.selectedShapeId = null;
    render();
    e.preventDefault();
  }
});

/* ==================== INIT ==================== */
render();
</script>
</body>
</html>
